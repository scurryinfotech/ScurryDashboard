@{
    ViewData["Title"] = "Payment History";
    Layout = "~/Views/Shared/_Layout.cshtml";
}
@section Styles {
<style>
    /* ── Welcome Banner ── */
    .dash-welcome {
        background: linear-gradient(135deg, var(--gns-surface) 0%, var(--gns-surface-2) 100%);
        border: 1px solid var(--gns-border);
        border-radius: var(--gns-radius);
        padding: 28px 32px;
        margin-bottom: 28px;
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 20px;
        flex-wrap: wrap;
        position: relative;
        overflow: hidden;
    }

        .dash-welcome::before {
            content: '';
            position: absolute;
            top: -40px; right: -40px;
            width: 180px; height: 180px;
            background: radial-gradient(circle, var(--gns-accent-glow), transparent 70%);
            pointer-events: none;
        }

    .dash-welcome__title {
        font-family: 'Syne', sans-serif;
        font-size: 1.6rem;
        font-weight: 800;
        margin: 0 0 4px;
        color: var(--gns-text);
    }

    .dash-welcome__sub {
        color: var(--gns-text-muted);
        font-size: .88rem;
        margin: 0;
    }

    /* ── Summary Stat Cards ── */
    .dash-stats {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
        gap: 16px;
        margin-bottom: 28px;
    }

    .dash-stat {
        background: var(--gns-surface);
        border: 1px solid var(--gns-border);
        border-radius: var(--gns-radius);
        padding: 22px;
        position: relative;
        overflow: hidden;
        transition: transform .2s, box-shadow .2s;
    }

        .dash-stat:hover {
            transform: translateY(-2px);
            box-shadow: 0 8px 32px rgba(0,0,0,.3);
        }

    .dash-stat__icon {
        width: 46px; height: 46px;
        border-radius: var(--gns-radius-sm);
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.2rem;
        margin-bottom: 14px;
    }

    .dash-stat__val {
        font-family: 'Syne', sans-serif;
        font-size: 1.75rem;
        font-weight: 800;
        line-height: 1;
        margin-bottom: 4px;
        color: var(--gns-text);
    }

    .dash-stat__label {
        font-size: .75rem;
        color: var(--gns-text-muted);
        font-weight: 500;
        letter-spacing: .04em;
        text-transform: uppercase;
    }

    /* ── Icon Colors ── */
    .icon-amber  { background: rgba(245,166,35,.15);  color: var(--gns-accent); }
    .icon-green  { background: rgba(34,197,94,.12);   color: #22c55e; }
    .icon-blue   { background: rgba(99,102,241,.12);  color: #818cf8; }
    .icon-red    { background: rgba(239,68,68,.12);   color: #ef4444; }
    .icon-purple { background: rgba(168,85,247,.12);  color: #c084fc; }
    .icon-cyan   { background: rgba(6,182,212,.12);   color: #22d3ee; }

    /* ── Card ── */
    .gns-card {
        background: var(--gns-surface);
        border: 1px solid var(--gns-border);
        border-radius: var(--gns-radius);
        overflow: hidden;
    }

    .gns-card__header {
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: 16px 20px;
        border-bottom: 1px solid var(--gns-border);
    }

    .gns-card__title {
        font-family: 'Syne', sans-serif;
        font-size: .95rem;
        font-weight: 700;
        margin: 0;
        color: var(--gns-text);
    }

    .gns-card__body {
        padding: 20px;
    }

    /* ── Table ── */
    .table {
        color: var(--gns-text);
    }

        .table thead th {
            font-size: .7rem;
            letter-spacing: .08em;
            text-transform: uppercase;
            color: var(--gns-text-muted);
            border-bottom: 1px solid var(--gns-border);
            padding: 10px 14px;
            font-weight: 600;
        }

        .table tbody td {
            font-size: .83rem;
            padding: 10px 14px;
            border-bottom: 1px solid rgba(255,255,255,0.04);
            vertical-align: middle;
        }

        .table tbody tr:hover {
            background: rgba(255,255,255,0.03);
        }

        .table tbody tr:last-child td {
            border-bottom: none;
        }

    /* ── Vendor Filter Select ── */
    .gns-input {
        background: var(--gns-surface-2) !important;
        border: 1px solid var(--gns-border) !important;
        border-radius: var(--gns-radius-sm) !important;
        color: var(--gns-text) !important;
        font-size: .85rem;
        padding: 8px 12px;
        transition: border-color .2s;
    }

        .gns-input:focus {
            outline: none;
            border-color: var(--gns-accent) !important;
            box-shadow: 0 0 0 3px var(--gns-accent-dim) !important;
        }

        .gns-input option {
            background: var(--gns-surface-2);
            color: var(--gns-text);
        }

    /* ── DataTables overrides ── */
    .dataTables_wrapper .dataTables_length select,
    .dataTables_wrapper .dataTables_filter input {
        background: var(--gns-surface-2);
        border: 1px solid var(--gns-border);
        border-radius: var(--gns-radius-sm);
        color: var(--gns-text);
        padding: 4px 10px;
    }

    .dataTables_wrapper .dataTables_info,
    .dataTables_wrapper .dataTables_length label,
    .dataTables_wrapper .dataTables_filter label {
        color: var(--gns-text-muted);
        font-size: .8rem;
    }

    .dataTables_wrapper .dataTables_paginate .paginate_button {
        color: var(--gns-text-muted) !important;
        border-radius: var(--gns-radius-sm) !important;
        border: 1px solid transparent !important;
    }

        .dataTables_wrapper .dataTables_paginate .paginate_button:hover {
            background: var(--gns-surface-2) !important;
            border-color: var(--gns-border) !important;
            color: var(--gns-text) !important;
        }

        .dataTables_wrapper .dataTables_paginate .paginate_button.current {
            background: var(--gns-accent-dim) !important;
            border-color: var(--gns-accent) !important;
            color: var(--gns-accent) !important;
            font-weight: 600;
        }

    @@media (max-width: 600px) {
        .dash-welcome {
            flex-direction: column;
            align-items: flex-start;
        }

        .dash-stats {
            grid-template-columns: 1fr 1fr;
        }
    }
</style>
}
<div class="dash-welcome" style="margin-bottom:20px">
    <div>
        <h1 class="dash-welcome__title">Payment History <i class="fas fa-history" style="color:var(--gns-accent)"></i></h1>
        <p class="dash-welcome__sub">Complete vendor payment records</p>
    </div>
    <div style="display:flex;gap:10px;align-items:center">
        <select id="filterVendor" class="form-select gns-input" style="width:200px">
            <option value="">All Vendors</option>
        </select>
    </div>
</div>

<!-- Summary Cards -->
<div class="dash-stats" id="paymentSummary" style="margin-bottom:20px">
    <div class="dash-stat">
        <div class="dash-stat__icon icon-amber"><i class="fas fa-receipt"></i></div>
        <div class="dash-stat__val" id="psTotal">—</div>
        <div class="dash-stat__label">Total Payments</div>
    </div>
    <div class="dash-stat">
        <div class="dash-stat__icon icon-green"><i class="fas fa-money-bill-wave"></i></div>
        <div class="dash-stat__val" id="psTotalAmt">—</div>
        <div class="dash-stat__label">Total Paid</div>
    </div>
    <div class="dash-stat">
        <div class="dash-stat__icon icon-blue"><i class="fas fa-building"></i></div>
        <div class="dash-stat__val" id="psVendors">—</div>
        <div class="dash-stat__label">Vendors Paid</div>
    </div>
</div>

<!-- Table -->
<div class="gns-card">
    <div class="gns-card__body" style="padding:0">
        <div class="table-responsive">
            <table class="table dataTable" id="paymentsTable" style="width:100%">
                <thead>
                    <tr>
                        <th>#</th>
                        <th>Vendor</th>
                        <th>Order #</th>
                        <th>Payment Date</th>
                        <th>Amount</th>
                        <th>Type</th>
                        <th>Method</th>
                        <th>Invoice #</th>
                    </tr>
                </thead>
                <tbody></tbody>
            </table>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        const Rs = v => 'Rs ' + Number(v).toLocaleString();
        let allPayments = [];

        $(function () {
            // Populate vendor filter
            $.get('/Vendors/GetAll', function (data) {
                const list = typeof data === 'string' ? JSON.parse(data) : data;
                let opts = '<option value="">All Vendors</option>';
                list.filter(v => v.isActive).forEach(v => {
                    opts += `<option value="${v.vendorId}">${v.vendorName}</option>`;
                });
                $('#filterVendor').html(opts);
            });

            // Check if filtered by order from URL
            const urlParams = new URLSearchParams(window.location.search);
            const orderId   = urlParams.get('orderId');
            const vendorId  = urlParams.get('vendorId');

            if (orderId) {
                loadByOrder(orderId);
            } else if (vendorId) {
                $('#filterVendor').val(vendorId);
                loadByVendor(vendorId);
            } else {
                loadAll();
            }

            $('#filterVendor').on('change', function () {
                const v = $(this).val();
                if (v) loadByVendor(v); else loadAll();
            });
        });

        function loadAll() {
            $.get('/VendorPayments/GetAll', function (data) {
                allPayments = typeof data === 'string' ? JSON.parse(data) : data;
                renderTable(allPayments);
                renderSummary(allPayments);
            });
        }

        function loadByVendor(vendorId) {
            $.get('/VendorPayments/GetByVendor?vendorId=' + vendorId, function (data) {
                allPayments = typeof data === 'string' ? JSON.parse(data) : data;
                renderTable(allPayments);
                renderSummary(allPayments);
            });
        }

        function loadByOrder(orderId) {
            $.get('/VendorPayments/GetByOrder?orderId=' + orderId, function (data) {
                allPayments = typeof data === 'string' ? JSON.parse(data) : data;
                renderTable(allPayments);
                renderSummary(allPayments);
            });
        }

        function renderSummary(data) {
            const totalAmt  = data.reduce((a, p) => a + (p.amount || 0), 0);
            const vendors   = new Set(data.map(p => p.vendorId)).size;
            $('#psTotal').text(data.length);
            $('#psTotalAmt').text(Rs(totalAmt));
            $('#psVendors').text(vendors);
        }

        function renderTable(data) {
            if ($.fn.DataTable.isDataTable('#paymentsTable'))
                $('#paymentsTable').DataTable().destroy();

            $('#paymentsTable').DataTable({
                data, destroy: true,
                pageLength: 15,
                order: [[3, 'desc']],
                columns: [
                    { data: 'paymentId' },
                    { data: 'vendorName', defaultContent: '—' },
                    { data: 'purchaseOrderId', render: id =>
                        `<a href="/PurchaseOrders/Index" style="color:var(--gns-accent)">#${id}</a>` },
                    { data: 'paymentDate', render: d => d ? d.substring(0,10) : '—' },
                    { data: 'amount', render: v =>
                        `<span style="font-family:Syne,sans-serif;font-weight:700;color:#22c55e">${Rs(v)}</span>` },
                    { data: 'paymentType', render: t => {
                        const col = { Advance:'#f5a623', Partial:'#818cf8', Full:'#22c55e' };
                        return `<span style="color:${col[t]||'var(--gns-text)'};font-weight:600">${t}</span>`;
                    }},
                    { data: 'paymentMethod' },
                    { data: 'invoiceNumber', defaultContent: '—' }
                ]
            });
        }
    </script>
}