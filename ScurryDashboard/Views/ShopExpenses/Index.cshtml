@{
    ViewData["Title"] = "Shop Expenses";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="gns-page-header">
    <div>
        <h1><i class="fas fa-store mr-2" style="color:var(--gns-accent)"></i>Shop Expenses</h1>
        <p>Track and manage all recurring shop-level expenses</p>
    </div>
    <button class="btn-gns btn-gns-primary" id="btnAddShopExp">
        <i class="fas fa-plus"></i> Add Expense
    </button>
</div>

<div class="gns-stats-row">
    <div class="gns-stat">
        <div class="gns-stat__icon"><i class="fas fa-receipt"></i></div>
        <div><div class="gns-stat__val" id="seStatTotal">—</div><div class="gns-stat__label">Total Records</div></div>
    </div>
    <div class="gns-stat">
        <div class="gns-stat__icon"><i class="fas fa-coins"></i></div>
        <div><div class="gns-stat__val" id="seStatSum">—</div><div class="gns-stat__label">Total Amount</div></div>
    </div>
    <div class="gns-stat">
        <div class="gns-stat__icon"><i class="fas fa-calendar-day"></i></div>
        <div><div class="gns-stat__val" id="seStatMonth">—</div><div class="gns-stat__label">This Month</div></div>
    </div>
</div>

<div class="gns-card" style="position:relative">
    <div class="gns-loader" id="seTblLoader"><div class="gns-spinner"></div></div>
    <div class="gns-card__header">
        <h2 class="gns-card__title">Expense Records</h2>
        <button class="btn-gns btn-gns-ghost" id="seRefresh"><i class="fas fa-rotate-right"></i></button>
    </div>
    <div class="gns-card__body" style="padding:0">
        <div class="table-responsive">
            <table id="shopExpTable" class="table dataTable" style="width:100%">
                <thead>
                    <tr>
                        <th>#</th>
                        <th>Title</th>
                        <th>Category</th>
                        <th>Amount</th>
                        <th>Date</th>
                        <th>Payment Mode</th>
                        <th>Status</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody></tbody>
            </table>
        </div>
    </div>
</div>

<!-- Modal -->
<div class="modal fade" id="shopExpModal" tabindex="-1">
    <div class="modal-dialog modal-lg modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="seModalTitle">Add Shop Expense</h5>
                <button type="button" class="close" data-dismiss="modal">&times;</button>
            </div>
            <div class="modal-body">
                <input type="hidden" id="seId" />
                <div class="gns-form-grid">
                    <div class="gns-form-group">
                        <label>Title *</label>
                        <input type="text" id="seTitle" class="gns-form-control" placeholder="e.g. Rent" />
                    </div>
                    <div class="gns-form-group">
                        <label>Category</label>
                        <input type="text" id="seCategory" class="gns-form-control" placeholder="e.g. Utilities" />
                    </div>
                    <div class="gns-form-group">
                        <label>Amount (Rs) *</label>
                        <input type="number" id="seAmount" class="gns-form-control" placeholder="0.00" />
                    </div>
                    <div class="gns-form-group">
                        <label>Date *</label>
                        <input type="date" id="seDate" class="gns-form-control" />
                    </div>
                    <div class="gns-form-group">
                        <label>Payment Mode</label>
                        <select id="dePaymentMode" class="gns-form-control">
                            <option value="Cash">💵 Cash</option>
                            <option value="Online">📱 Online</option>
                            <option value="Cheque">📝 Cheque</option>
                            <option value="Bank Transfer">🏦 Bank Transfer</option>
                        </select>
                    </div>
                </div>
                <div class="gns-form-group">
                    <label>Description</label>
                    <textarea id="seDesc" class="gns-form-control" rows="3" placeholder="Optional notes…"></textarea>
                </div>
                <div class="gns-form-group">
                    <label>Status</label>
                    <select id="seIsActive" class="gns-form-control" style="max-width:220px">
                        <option value="true">Active</option>
                        <option value="false">Inactive</option>
                    </select>
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn-gns btn-gns-ghost" data-dismiss="modal">Cancel</button>
                <button type="button" class="btn-gns btn-gns-primary" id="seSave">
                    <i class="fas fa-floppy-disk"></i> Save
                </button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="~/js/Shopexpenses.js" asp-append-version="true"></script>
}
