@{
    ViewData["Title"] = "Dashboard";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

@section Styles {
    <style>
        .dash-welcome {
            background: linear-gradient(135deg, var(--gns-surface) 0%, var(--gns-surface-2) 100%);
            border: 1px solid var(--gns-border);
            border-radius: var(--gns-radius);
            padding: 28px 32px;
            margin-bottom: 28px;
            display: flex;
            align-items: center;
            justify-content: space-between;
            gap: 20px;
            flex-wrap: wrap;
            position: relative;
            overflow: hidden;
        }

            .dash-welcome::before {
                content: '';
                position: absolute;
                top: -40px;
                right: -40px;
                width: 180px;
                height: 180px;
                background: radial-gradient(circle, var(--gns-accent-glow), transparent 70%);
                pointer-events: none;
            }

        .dash-welcome__title {
            font-family: 'Syne', sans-serif;
            font-size: 1.6rem;
            font-weight: 800;
            margin: 0 0 4px;
            color: var(--gns-text);
        }

        .dash-welcome__sub {
            color: var(--gns-text-muted);
            font-size: .88rem;
            margin: 0;
        }

        .dash-welcome__date {
            font-family: 'Syne', sans-serif;
            font-size: .85rem;
            font-weight: 600;
            color: var(--gns-accent);
            background: var(--gns-accent-dim);
            padding: 8px 18px;
            border-radius: 99px;
            white-space: nowrap;
        }

        /* ── Summary Stats ── */
        .dash-stats {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
            gap: 16px;
            margin-bottom: 28px;
        }

        .dash-stat {
            background: var(--gns-surface);
            border: 1px solid var(--gns-border);
            border-radius: var(--gns-radius);
            padding: 22px;
            position: relative;
            overflow: hidden;
            transition: transform .2s, box-shadow .2s;
        }

            .dash-stat:hover {
                transform: translateY(-2px);
                box-shadow: 0 8px 32px rgba(0,0,0,.3);
            }

        .dash-stat__icon {
            width: 46px;
            height: 46px;
            border-radius: var(--gns-radius-sm);
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 1.2rem;
            margin-bottom: 14px;
        }

        .dash-stat__val {
            font-family: 'Syne', sans-serif;
            font-size: 1.75rem;
            font-weight: 800;
            line-height: 1;
            margin-bottom: 4px;
        }

        .dash-stat__label {
            font-size: .75rem;
            color: var(--gns-text-muted);
            font-weight: 500;
            letter-spacing: .04em;
            text-transform: uppercase;
        }

        .dash-stat__trend {
            position: absolute;
            bottom: 16px;
            right: 18px;
            font-size: .72rem;
            font-weight: 600;
        }

        .trend-up {
            color: #22c55e;
        }

        .trend-down {
            color: #ef4444;
        }

        .icon-amber {
            background: rgba(245,166,35,.15);
            color: var(--gns-accent);
        }

        .icon-green {
            background: rgba(34,197,94,.12);
            color: #22c55e;
        }

        .icon-blue {
            background: rgba(99,102,241,.12);
            color: #818cf8;
        }

        .icon-red {
            background: rgba(239,68,68,.12);
            color: #ef4444;
        }

        .icon-purple {
            background: rgba(168,85,247,.12);
            color: #c084fc;
        }

        .icon-cyan {
            background: rgba(6,182,212,.12);
            color: #22d3ee;
        }

        /* ── Charts Row ── */
        .dash-charts {
            display: grid;
            grid-template-columns: 2fr 1fr;
            gap: 20px;
            margin-bottom: 28px;
        }
        @@media(max - width:900px) {
            .dash-charts {
                grid-template-columns: 1fr;
            }
        }

        .chart-box {
            background: var(--gns-surface);
            border: 1px solid var(--gns-border);
            border-radius: var(--gns-radius);
            padding: 22px;
        }

        .chart-box__title {
            font-family: 'Syne', sans-serif;
            font-size: .95rem;
            font-weight: 700;
            margin: 0 0 20px;
            color: var(--gns-text);
            display: flex;
            align-items: center;
            gap: 8px;
        }

            .chart-box__title i {
                color: var(--gns-accent);
            }

        canvas {
            max-width: 100%;
        }

        /* ── Recent Tables Row ── */
        .dash-tables {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 20px;
            margin-bottom: 28px;
        }
        @@media(max - width:900px) {
            .dash-tables {
                grid-template-columns: 1fr;
            }
        }

        .recent-table th {
            font-size: .7rem !important;
            letter-spacing: .08em !important;
        }

        .recent-table td {
            font-size: .83rem !important;
        }

        /* Staff section */
        .dash-staff-section {
            margin-bottom: 28px;
        }
    </style>
}

<!-- ── Welcome Banner ───────────────────────────────────────── -->
<div class="dash-welcome">
    <div>
        <h1 class="dash-welcome__title">Welcome back, Admin 👋</h1>
        <p class="dash-welcome__sub">Here's what's happening at Grill N Shakes today.</p>
    </div>
    <div class="dash-welcome__date" id="dashDate">—</div>
</div>

<!-- ── Summary Stats ────────────────────────────────────────── -->
<div class="dash-stats">
    <div class="dash-stat">
        <div class="dash-stat__icon icon-amber"><i class="fas fa-users"></i></div>
        <div class="dash-stat__val" id="dsTotalStaff">—</div>
        <div class="dash-stat__label">Total Staff</div>
        <div class="dash-stat__trend trend-up" id="dsActiveStaff">— active</div>
    </div>
    <div class="dash-stat">
        <div class="dash-stat__icon icon-green"><i class="fas fa-circle-check"></i></div>
        <div class="dash-stat__val" id="dsActiveStaffCount">—</div>
        <div class="dash-stat__label">Active Staff</div>
    </div>
    <div class="dash-stat">
        <div class="dash-stat__icon icon-red"><i class="fas fa-store"></i></div>
        <div class="dash-stat__val" id="dsTotalShopExp">—</div>
        <div class="dash-stat__label">Shop Expenses</div>
        <div class="dash-stat__trend" id="dsShopExpCount" style="color:var(--gns-text-muted)">— records</div>
    </div>
    <div class="dash-stat">
        <div class="dash-stat__icon icon-blue"><i class="fas fa-receipt"></i></div>
        <div class="dash-stat__val" id="dsTotalDailyExp">—</div>
        <div class="dash-stat__label">Daily Expenses</div>
        <div class="dash-stat__trend" id="dsDailyExpCount" style="color:var(--gns-text-muted)">— records</div>
    </div>
    <div class="dash-stat">
        <div class="dash-stat__icon icon-purple"><i class="fas fa-calendar-day"></i></div>
        <div class="dash-stat__val" id="dsTodayExp">—</div>
        <div class="dash-stat__label">Today's Expenses</div>
    </div>
    <div class="dash-stat">
        <div class="dash-stat__icon icon-cyan"><i class="fas fa-money-bill-wave"></i></div>
        <div class="dash-stat__val" id="dsTotalSalary">—</div>
        <div class="dash-stat__label">Monthly Salary</div>
    </div>
</div>

<!-- ── Charts ────────────────────────────────────────────────── -->
<div class="dash-charts">
    <!-- Line Chart — last 7 days expenses -->
    <div class="chart-box">
        <div class="chart-box__title">
            <i class="fas fa-chart-line"></i> Expenses — Last 7 Days
        </div>
        <canvas id="chartExpenses" height="110"></canvas>
    </div>
    <!-- Doughnut — expense breakdown -->
    <div class="chart-box">
        <div class="chart-box__title">
            <i class="fas fa-chart-pie"></i> Expense Breakdown
        </div>
        <canvas id="chartBreakdown" height="200"></canvas>
    </div>
</div>

<!-- ── Recent Records ────────────────────────────────────────── -->
<div class="dash-tables">
    <!-- Recent Shop Expenses -->
    <div class="gns-card">
        <div class="gns-card__header">
            <h2 class="gns-card__title"><i class="fas fa-store mr-2" style="color:var(--gns-accent)"></i>Recent Shop Expenses</h2>
            <a asp-controller="ShopExpenses" asp-action="Index" class="btn-gns btn-gns-ghost" style="padding:5px 12px;font-size:.78rem">View All</a>
        </div>
        <div class="gns-card__body" style="padding:0">
            <table class="table recent-table" id="recentShopExp" style="margin:0;width:100%">
                <thead>
                    <tr>
                        <th style="padding:10px 14px">Title</th>
                        <th style="padding:10px 14px">Category</th>
                        <th style="padding:10px 14px">Amount</th>
                        <th style="padding:10px 14px">Date</th>
                    </tr>
                </thead>
                <tbody id="recentShopExpBody">
                    <tr><td colspan="4" class="text-center" style="padding:20px;color:var(--gns-text-muted)"><i class="fas fa-spinner fa-spin"></i> Loading…</td></tr>
                </tbody>
            </table>
        </div>
    </div>

    <!-- Recent Daily Expenses -->
    <div class="gns-card">
        <div class="gns-card__header">
            <h2 class="gns-card__title"><i class="fas fa-receipt mr-2" style="color:var(--gns-accent)"></i>Recent Daily Expenses</h2>
            <a asp-controller="DailyExpenses" asp-action="Index" class="btn-gns btn-gns-ghost" style="padding:5px 12px;font-size:.78rem">View All</a>
        </div>
        <div class="gns-card__body" style="padding:0">
            <table class="table recent-table" id="recentDailyExp" style="margin:0;width:100%">
                <thead>
                    <tr>
                        <th style="padding:10px 14px">Title</th>
                        <th style="padding:10px 14px">Category</th>
                        <th style="padding:10px 14px">Amount</th>
                        <th style="padding:10px 14px">Date</th>
                    </tr>
                </thead>
                <tbody id="recentDailyExpBody">
                    <tr><td colspan="4" class="text-center" style="padding:20px;color:var(--gns-text-muted)"><i class="fas fa-spinner fa-spin"></i> Loading…</td></tr>
                </tbody>
            </table>
        </div>
    </div>
</div>

<!-- ── Staff Table ────────────────────────────────────────────── -->
<div class="gns-card dash-staff-section">
    <div class="gns-card__header">
        <h2 class="gns-card__title"><i class="fas fa-users mr-2" style="color:var(--gns-accent)"></i>All Staff Members</h2>
        <a asp-controller="Staff" asp-action="Index" class="btn-gns btn-gns-ghost" style="padding:5px 12px;font-size:.78rem">Manage Staff</a>
    </div>
    <div class="gns-card__body" style="padding:0">
        <div class="table-responsive">
            <table class="table recent-table dataTable" id="dashStaffTable" style="width:100%">
                <thead>
                    <tr>
                        <th>#</th>
                        <th>Name</th>
                        <th>Role</th>
                        <th>Department</th>
                        <th>Phone</th>
                        <th>Salary</th>
                        <th>Status</th>
                    </tr>
                </thead>
                <tbody></tbody>
            </table>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js"></script>
    <script>
        $(function () {

            // ── Date display ──────────────────────────────────────────
            const now = new Date();
            $('#dashDate').text(now.toLocaleDateString('en-PK', {
                weekday: 'long', year: 'numeric', month: 'long', day: 'numeric'
            }));

            // ── Chart.js defaults ─────────────────────────────────────
            Chart.defaults.color          = '#8a8070';
            Chart.defaults.borderColor    = 'rgba(255,255,255,0.06)';
            Chart.defaults.font.family    = 'DM Sans, sans-serif';

            let lineChart, donutChart;

            // ── Rs formatter ─────────────────────────────────────────
            const Rs = v => 'Rs ' + Number(v).toLocaleString();

            // ── Last 7 days labels ────────────────────────────────────
            function last7Days() {
                const days = [];
                for (let i = 6; i >= 0; i--) {
                    const d = new Date(); d.setDate(d.getDate() - i);
                    days.push(d.toISOString().substring(0, 10));
                }
                return days;
            }

            function dayLabel(iso) {
                return new Date(iso).toLocaleDateString('en-PK', { weekday: 'short', day: 'numeric' });
            }

            // ── Build line chart ──────────────────────────────────────
            function buildLineChart(shopData, dailyData) {
                const days = last7Days();

                function sumByDay(data, days) {
                    return days.map(day =>
                        data.filter(x => x.expenseDate && x.expenseDate.substring(0, 10) === day)
                            .reduce((a, x) => a + (x.amount || 0), 0)
                    );
                }

                const shopAmts  = sumByDay(shopData,  days);
                const dailyAmts = sumByDay(dailyData, days);
                const labels    = days.map(dayLabel);

                if (lineChart) lineChart.destroy();

                lineChart = new Chart(document.getElementById('chartExpenses'), {
                    type: 'line',
                    data: {
                        labels,
                        datasets: [
                            {
                                label: 'Shop Expenses',
                                data: shopAmts,
                                borderColor: '#f5a623',
                                backgroundColor: 'rgba(245,166,35,0.08)',
                                borderWidth: 2.5,
                                pointBackgroundColor: '#f5a623',
                                pointRadius: 4,
                                tension: 0.4,
                                fill: true,
                            },
                            {
                                label: 'Daily Expenses',
                                data: dailyAmts,
                                borderColor: '#818cf8',
                                backgroundColor: 'rgba(129,140,248,0.08)',
                                borderWidth: 2.5,
                                pointBackgroundColor: '#818cf8',
                                pointRadius: 4,
                                tension: 0.4,
                                fill: true,
                            }
                        ]
                    },
                    options: {
                        responsive: true,
                        plugins: {
                            legend: { labels: { color: '#8a8070', boxWidth: 12, padding: 16 } },
                            tooltip: {
                                backgroundColor: '#1a1815',
                                borderColor: 'rgba(255,255,255,0.1)',
                                borderWidth: 1,
                                callbacks: {
                                    label: ctx => ' ' + Rs(ctx.parsed.y)
                                }
                            }
                        },
                        scales: {
                            x: { ticks: { color: '#8a8070' }, grid: { color: 'rgba(255,255,255,0.04)' } },
                            y: { ticks: { color: '#8a8070', callback: v => 'Rs ' + Number(v).toLocaleString() },
                                 grid: { color: 'rgba(255,255,255,0.04)' } }
                        }
                    }
                });
            }

            // ── Build donut chart ─────────────────────────────────────
            function buildDonutChart(shopTotal, dailyTotal, salaryTotal) {
                if (donutChart) donutChart.destroy();

                donutChart = new Chart(document.getElementById('chartBreakdown'), {
                    type: 'doughnut',
                    data: {
                        labels: ['Shop Expenses', 'Daily Expenses', 'Staff Salary'],
                        datasets: [{
                            data: [shopTotal, dailyTotal, salaryTotal],
                            backgroundColor: ['#f5a623', '#818cf8', '#22c55e'],
                            borderColor: '#1a1815',
                            borderWidth: 3,
                            hoverOffset: 6
                        }]
                    },
                    options: {
                        responsive: true,
                        cutout: '68%',
                        plugins: {
                            legend: {
                                position: 'bottom',
                                labels: { color: '#8a8070', boxWidth: 10, padding: 14 }
                            },
                            tooltip: {
                                backgroundColor: '#1a1815',
                                borderColor: 'rgba(255,255,255,0.1)',
                                borderWidth: 1,
                                callbacks: {
                                    label: ctx => ' ' + Rs(ctx.parsed)
                                }
                            }
                        }
                    }
                });
            }

            // ── Recent table rows ─────────────────────────────────────
            function renderRecentRows(data, tbodyId, idField) {
                const recent = [...data]
                    .sort((a, b) => new Date(b.expenseDate) - new Date(a.expenseDate))
                    .slice(0, 6);

                if (!recent.length) {
                    $(`#${tbodyId}`).html(`<tr><td colspan="4" class="text-center" style="padding:20px;color:var(--gns-text-muted)">No records found</td></tr>`);
                    return;
                }

                const rows = recent.map(x => `
                    <tr>
                        <td style="padding:10px 14px;color:var(--gns-text)">${x.title}</td>
                        <td style="padding:10px 14px;color:var(--gns-text-muted)">${x.category || '—'}</td>
                        <td style="padding:10px 14px;font-family:Syne,sans-serif;font-weight:700;color:var(--gns-accent)">Rs ${Number(x.amount).toLocaleString()}</td>
                        <td style="padding:10px 14px;color:var(--gns-text-muted)">${x.expenseDate ? x.expenseDate.substring(0,10) : '—'}</td>
                    </tr>`).join('');
                $(`#${tbodyId}`).html(rows);
            }

            // ── Staff DataTable ───────────────────────────────────────
            function buildStaffTable(data) {
                if ($.fn.DataTable.isDataTable('#dashStaffTable'))
                    $('#dashStaffTable').DataTable().destroy();

                $('#dashStaffTable').DataTable({
                    data, destroy: true, pageLength: 5,
                    order: [[0, 'desc']],
                    columns: [
                        { data: 'staffId' },
                        { data: 'fullName' },
                        { data: 'roleName',   defaultContent: '—' },
                        { data: 'department', defaultContent: '—' },
                        { data: 'phone',      defaultContent: '—' },
                        { data: 'salary',
                          render: v => `<span style="font-family:Syne,sans-serif;font-weight:700;color:var(--gns-accent)">Rs ${Number(v).toLocaleString()}</span>` },
                        { data: 'isActive',
                          render: v => v
                            ? '<span class="gns-badge gns-badge-active">Active</span>'
                            : '<span class="gns-badge gns-badge-inactive">Inactive</span>' }
                    ]
                });
            }

            // ── Load all data ─────────────────────────────────────────
            let shopData = [], dailyData = [], staffData = [];
            let loaded = 0;

            function checkAllLoaded() {
                loaded++;
                if (loaded < 3) return;

                // ── Stats ──
                const activeStaff  = staffData.filter(s => s.isActive).length;
                const totalSalary  = staffData.filter(s => s.isActive).reduce((a, s) => a + (s.salary || 0), 0);
                const totalShop    = shopData.reduce((a, x)  => a + (x.amount || 0), 0);
                const totalDaily   = dailyData.reduce((a, x) => a + (x.amount || 0), 0);

                const todayStr = new Date().toISOString().substring(0, 10);
                const todayExp = [...shopData, ...dailyData]
                    .filter(x => x.expenseDate && x.expenseDate.substring(0, 10) === todayStr)
                    .reduce((a, x) => a + (x.amount || 0), 0);

                $('#dsTotalStaff').text(staffData.length);
                $('#dsActiveStaff').text(activeStaff + ' active');
                $('#dsActiveStaffCount').text(activeStaff);
                $('#dsTotalShopExp').text(Rs(totalShop));
                $('#dsShopExpCount').text(shopData.length + ' records');
                $('#dsTotalDailyExp').text(Rs(totalDaily));
                $('#dsDailyExpCount').text(dailyData.length + ' records');
                $('#dsTodayExp').text(Rs(todayExp));
                $('#dsTotalSalary').text(Rs(totalSalary));

                // ── Charts ──
                buildLineChart(shopData, dailyData);
                buildDonutChart(totalShop, totalDaily, totalSalary);

                // ── Recent tables ──
                renderRecentRows(shopData,  'recentShopExpBody',  'expenseId');
                renderRecentRows(dailyData, 'recentDailyExpBody', 'dailyExpenseId');

                // ── Staff table ──
                buildStaffTable(staffData);
            }

            // Staff
            $.ajax({
                url: '/Staff/GetAll', method: 'GET',
                success: data => { staffData = data || []; checkAllLoaded(); },
                error: ()    => { staffData = [];          checkAllLoaded(); }
            });

            // Shop Expenses
            $.ajax({
                url: '/ShopExpenses/GetAll', method: 'GET',
                success: data => { shopData = data || []; checkAllLoaded(); },
                error: ()    => { shopData = [];          checkAllLoaded(); }
            });

            // Daily Expenses
            $.ajax({
                url: '/DailyExpenses/GetAll', method: 'GET',
                success: data => { dailyData = data || []; checkAllLoaded(); },
                error: ()    => { dailyData = [];          checkAllLoaded(); }
            });

        });
    </script>
}
