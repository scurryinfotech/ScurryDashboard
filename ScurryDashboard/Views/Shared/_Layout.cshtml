<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"]</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/StyleSheet1.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/Dashboard.css" asp-append-version="true" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@4.0.0/dist/css/bootstrap.min.css">
    <link rel="stylesheet" href="https://cdn.datatables.net/1.10.15/css/dataTables.bootstrap4.min.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
    @RenderSection("Styles", required: false)
</head>
<body>

    <aside class="gns-sidebar" id="gnsSidebar">
        <div class="gns-sidebar__brand">
            <span class="gns-sidebar__brand-icon"><i class="fas fa-fire-flame-curved"></i></span>
            <span class="gns-sidebar__brand-text">Grill<em>N</em>Shakes</span>
        </div>

        <nav class="gns-sidebar__nav">

            <div class="gns-sidebar__section-label">Overview</div>

            <a class="gns-sidebar__link @(ViewContext.RouteData.Values["action"]?.ToString() == "Index" && ViewContext.RouteData.Values["controller"]?.ToString() == "Home" ? "active" : "")"
               asp-controller="Home" asp-action="Index">
                <i class="fa-solid fa-house"></i><span>Home</span>
            </a>

            <a class="gns-sidebar__link @(ViewContext.RouteData.Values["action"]?.ToString() == "Index" && ViewContext.RouteData.Values["controller"]?.ToString() == "DashboardContrller" ? "active" : "")"
               asp-controller="Dashboard" asp-action="Index">
                <i class="fas fa-gauge-high"></i><span>Dashboard</span>
            </a>

            <div class="gns-sidebar__section-label">Management</div>

            <a class="gns-sidebar__link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Staff" ? "active" : "")"
               asp-controller="Staff" asp-action="Index">
                <i class="fas fa-users"></i><span>Staff</span>
            </a>

            <a class="gns-sidebar__link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Salary" ? "active" : "")"
               asp-controller="Salary" asp-action="Index">
                <i class="fas fa-money-check-dollar"></i><span>Salary</span>
            </a>

            <a class="gns-sidebar__link @(ViewContext.RouteData.Values["controller"]?.ToString() == "ShopExpenses" ? "active" : "")"
               asp-controller="ShopExpenses" asp-action="Index">
                <i class="fas fa-store"></i><span>Shop Expenses</span>
            </a>

            <a class="gns-sidebar__link @(ViewContext.RouteData.Values["controller"]?.ToString() == "DailyExpenses" ? "active" : "")"
               asp-controller="DailyExpenses" asp-action="Index">
                <i class="fas fa-receipt"></i><span>Daily Expenses</span>
            </a>

            <div class="gns-sidebar__section-label">Orders</div>

            <a class="gns-sidebar__link @(ViewContext.RouteData.Values["action"]?.ToString() == "ManageMenu" ? "active" : "")"
               asp-controller="Home" asp-action="ManageMenu">
                <i class="fas fa-utensils"></i><span>Manage Menu</span>
            </a>

            <div class="gns-sidebar__section-label">Quick Actions</div>

            <a class="gns-sidebar__link @(ViewContext.RouteData.Values["action"]?.ToString() == "TableManager" ? "active" : "")"
               asp-controller="Home" asp-action="TableManager">
                <i class="fas fa-table-cells-large" style="color:#e67e22"></i>
                <span>Table Manager</span>
            </a>

            <a class="gns-sidebar__link @(ViewContext.RouteData.Values["action"]?.ToString() == "NewOrder" ? "active" : "")"
               asp-controller="Home" asp-action="NewOrder">
                <i class="fas fa-plus-circle" style="color:#27ae60"></i>
                <span>New Order</span>
            </a>

            <a class="gns-sidebar__link @(ViewContext.RouteData.Values["action"]?.ToString() == "PhoneOrder" ? "active" : "")"
               asp-controller="Home" asp-action="PhoneOrder">
                <i class="fas fa-phone-volume" style="color:#e67e22"></i>
                <span>Phone Order</span>
            </a>

        </nav>

        <div class="gns-sidebar__footer">
            <div class="gns-sidebar__user">
                <div class="gns-sidebar__avatar">GN</div>
                <div>
                    <div class="gns-sidebar__username">Admin</div>
                    <div class="gns-sidebar__role">System User</div>
                </div>
            </div>
        </div>
    </aside>

    <div class="gns-main" id="gnsMain">

        <header class="gns-topbar">
            <button class="gns-topbar__toggle" id="sidebarToggle" title="Toggle Sidebar">
                <i class="fas fa-bars"></i>
            </button>
            <div class="gns-topbar__breadcrumb">
                <span>@ViewData["Title"]</span>
            </div>
            <div class="gns-topbar__actions">

                <!-- Table Manager button -->
                <a asp-controller="Home" asp-action="TableManager"
                   style="display:inline-flex;align-items:center;gap:6px;background:linear-gradient(135deg,#e67e22,#d35400);color:#fff;border:none;border-radius:7px;padding:7px 15px;font-size:.8rem;font-weight:800;text-decoration:none;box-shadow:0 3px 10px rgba(230,126,34,.35);">
                    <i class="fas fa-table-cells-large"></i> Tables
                </a>

                <!-- New Order button -->
                <a asp-controller="Home" asp-action="NewOrder"
                   style="display:inline-flex;align-items:center;gap:6px;background:linear-gradient(135deg,#27ae60,#1e8449);color:#fff;border:none;border-radius:7px;padding:7px 15px;font-size:.8rem;font-weight:800;text-decoration:none;box-shadow:0 3px 10px rgba(39,174,96,.35);">
                    <i class="fas fa-plus"></i> New Order
                </a>

                <!-- Phone Order button -->
                <a asp-controller="Home" asp-action="PhoneOrder"
                   style="display:inline-flex;align-items:center;gap:6px;background:linear-gradient(135deg,#d35400,#e67e22);color:#fff;border:none;border-radius:7px;padding:7px 15px;font-size:.8rem;font-weight:800;text-decoration:none;box-shadow:0 3px 10px rgba(211,84,0,.3);">
                    <i class="fas fa-phone-volume"></i> Phone Order
                </a>

                <!-- Home Delivery -->
                <button id="HomeBtn" class="gns-delivery-btn" data-state="disconnected"
                        title="Connect/Disconnect Home Delivery">
                    <i class="fas fa-motorcycle"></i>
                    <span class="gns-delivery-btn__text">Home Delivery</span>
                    <span class="gns-delivery-btn__dot"></span>
                </button>
                <small id="HomeStatus" class="gns-delivery-status">Disconnected</small>

            </div>
        </header>

        <div id="toastContainer" class="gns-toast-container" aria-live="polite"></div>

        <main class="gns-content">
            @RenderBody()
        </main>
    </div>

    <script src="https://code.jquery.com/jquery-3.7.1.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/popper.js@1.16.1/dist/umd/popper.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@4.6.2/dist/js/bootstrap.min.js"></script>
    <script src="https://cdn.datatables.net/1.13.6/js/jquery.dataTables.min.js"></script>
    <script src="https://cdn.datatables.net/1.13.6/js/dataTables.bootstrap4.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    <script src="~/js/home.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)

</body>
</html>
