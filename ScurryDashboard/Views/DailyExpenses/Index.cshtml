@{
    ViewData["Title"] = "Daily Expenses";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="gns-page-header">
    <div>
        <h1><i class="fas fa-receipt mr-2" style="color:var(--gns-accent)"></i>Daily Expenses</h1>
        <p>Record and track day-to-day operational costs</p>
    </div>
    <button class="btn-gns btn-gns-primary" id="btnAddDE">
        <i class="fas fa-plus"></i> Add Expense
    </button>
</div>

<div class="gns-stats-row">
    <div class="gns-stat">
        <div class="gns-stat__icon"><i class="fas fa-list-check"></i></div>
        <div><div class="gns-stat__val" id="deStatTotal">—</div><div class="gns-stat__label">Total Records</div></div>
    </div>
    <div class="gns-stat">
        <div class="gns-stat__icon"><i class="fas fa-coins"></i></div>
        <div><div class="gns-stat__val" id="deStatToday">—</div><div class="gns-stat__label">Today's Total</div></div>
    </div>
    <div class="gns-stat">
        <div class="gns-stat__icon"><i class="fas fa-calendar-week"></i></div>
        <div><div class="gns-stat__val" id="deStatWeek">—</div><div class="gns-stat__label">This Week</div></div>
    </div>
</div>

<div class="gns-card" style="position:relative">
    <div class="gns-loader" id="deTblLoader"><div class="gns-spinner"></div></div>
    <div class="gns-card__header">
        <h2 class="gns-card__title">Expense Log</h2>
        <button class="btn-gns btn-gns-ghost" id="deRefresh"><i class="fas fa-rotate-right"></i></button>
    </div>
    <div class="gns-card__body" style="padding:0">
        <div class="table-responsive">
            <table id="dailyExpTable" class="table dataTable" style="width:100%">
                <thead>
                    <tr>
                        <th>#</th>
                        <th>Title</th>
                        <th>Category</th>
                        <th>Amount</th>
                        <th>Date</th>
                        <th>Paid By</th>
                        <th>Status</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody></tbody>
            </table>
        </div>
    </div>
</div>

<!-- Modal -->
<div class="modal fade" id="deModal" tabindex="-1">
    <div class="modal-dialog modal-lg modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="deModalTitle">Add Daily Expense</h5>
                <button type="button" class="close" data-dismiss="modal">&times;</button>
            </div>
            <div class="modal-body">
                <input type="hidden" id="deId" />
                <div class="gns-form-grid">
                    <div class="gns-form-group">
                        <label>Title *</label>
                        <input type="text" id="deTitle" class="gns-form-control" placeholder="e.g. Vegetable Purchase" />
                    </div>
                    <div class="gns-form-group">
                        <label>Category</label>
                        <input type="text" id="deCategory" class="gns-form-control" placeholder="e.g. Raw Material" />
                    </div>
                    <div class="gns-form-group">
                        <label>Amount (PKR) *</label>
                        <input type="number" id="deAmount" class="gns-form-control" placeholder="0.00" />
                    </div>
                    <div class="gns-form-group">
                        <label>Date *</label>
                        <input type="date" id="deDate" class="gns-form-control" />
                    </div>
                    <div class="gns-form-group">
                        <label>Paid By</label>
                        <input type="text" id="dePaidBy" class="gns-form-control" placeholder="e.g. Manager" />
                    </div>
                    <div class="gns-form-group">
                        <label>Status</label>
                        <select id="deIsActive" class="gns-form-control">
                            <option value="true">Active</option>
                            <option value="false">Inactive</option>
                        </select>
                    </div>
                </div>
                <div class="gns-form-group">
                    <label>Notes</label>
                    <textarea id="deNotes" class="gns-form-control" rows="3" placeholder="Optional notes…"></textarea>
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn-gns btn-gns-ghost" data-dismiss="modal">Cancel</button>
                <button type="button" class="btn-gns btn-gns-primary" id="deSave">
                    <i class="fas fa-floppy-disk"></i> Save
                </button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="~/js/Dailyexpenses.js" asp-append-version="true"></script>
}
