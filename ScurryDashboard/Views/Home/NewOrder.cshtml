@{
    ViewData["Title"] = "New Order";
    Layout = "~/Views/Shared/_NewOrderLayout.cshtml";
}

<div id="noWrap">

    <div class="no-top">
        <a class="no-top-logo" href="/">
            <i class="fas fa-fire-flame-curved"></i>
            <span>GrillNShakes</span>
        </a>
>

        <div class="no-top-search">
            <div class="no-srch-box">
                <i class="fas fa-search"></i>
                <input type="text" id="noSearch" placeholder="Search item..." oninput="filterMenu()" />
            </div>
            <input class="no-sc-inp" type="text" id="noSC" placeholder="Short Code" oninput="filterMenu()" />
        </div>

        <div class="no-top-types " >

            <div class="no-type-tab"        data-ot="Table"    onclick="setType(this)">Table</div>
        </div>

        <div class="no-tbl-wrap" id="noTblWrap">
            <label>Table:</label>
            <select id="noTableSel"></select>
        </div>

        <a class="no-top-back" href="/">
            <i class="fas fa-arrow-left"></i> Back
        </a>
    </div>

    <div class="no-cust-bar">
        <span class="no-cust-bar-lbl">Customer:</span>
        <input class="no-cust-inp name"  type="text" id="noCustName"  placeholder="Name " />
        <input class="no-cust-inp phone" type="tel"  id="noCustPhone" placeholder="Phone " />
        <input class="no-cust-inp addr"  type="text" id="noCustAddr"  placeholder="Delivery Address" />
    </div>

    <div class="no-body">

        <div class="no-cats" id="noCatBar"></div>

        <div class="no-center">

            <div class="no-subbar" id="noSubBar" style="display:none"></div>

            <div class="no-grid" id="noGrid"></div>

            <div class="no-detail" id="noDetailPanel">
                <div class="no-detail-top">
                    <div>
                        <div class="no-detail-name" id="noDetailName">Item</div>
                        <div class="no-detail-code" id="noDetailCode"></div>
                    </div>
                    <button class="no-detail-x" onclick="closeDetail()">&times;</button>
                </div>
                <div class="no-portions">
                    <div class="no-portion active" id="noPortionFull" onclick="selPortion('full')">
                        <div class="no-portion-lbl">Full</div>
                        <div class="no-portion-pr" id="noDetailFP">&#8377;0</div>
                    </div>
                    <div class="no-portion" id="noPortionHalf" onclick="selPortion('half')">
                        <div class="no-portion-lbl">Half</div>
                        <div class="no-portion-pr" id="noDetailHP">N/A</div>
                    </div>
                </div>
                <div class="no-detail-row">
                    <button class="no-dqb minus" onclick="detailChgQty(-1)">&#8722;</button>
                    <span   class="no-dqv" id="noDetailQty">1</span>
                    <button class="no-dqb plus"  onclick="detailChgQty(1)">+</button>
                    <input  class="no-detail-note" type="text" id="noDetailNote" placeholder="Special instruction (optional)" />
                    <button class="no-detail-add" onclick="detailAdd()">
                        <i class="fas fa-cart-plus"></i> Add to Order
                    </button>
                </div>
            </div>

        </div>

        <div class="no-right">

            <div class="no-cart-hdr">
                <div class="no-cart-hdr-labels">
                    <span class="no-hdr-item">ITEMS</span>
                    <span class="no-hdr-qty">QTY.</span>
                    <span class="no-hdr-price">PRICE</span>
                </div>
            </div>

            <div class="no-clist" id="noCartList">
                <div class="no-empty">
                    <i class="fas fa-cart-shopping"></i>
                    <p>No items selected</p>
                </div>
            </div>





            <div class="no-actions-place">
                <button class="no-abtn-place" id="noBtnPlace" onclick="noPlace()" disabled>
                    <i class="fas fa-check-circle"></i> Place Order
                </button>
            </div>

        </div>
    </div>
</div>

<div class="no-modal-bg" id="noKOTModal">
    <div class="no-modal-box">
        <div class="no-modal-hdr">
            <h4><i class="fas fa-receipt" style="color:#e67e22;margin-right:6px"></i>Kitchen Order Ticket</h4>
            <button class="no-modal-x" onclick="document.getElementById('noKOTModal').classList.remove('open')">&times;</button>
        </div>
        <div class="no-modal-body"><div class="no-pzone" id="noKOTPrint"></div></div>
        <div class="no-modal-ftr">
            <button class="no-btn no-btn-gh"  onclick="document.getElementById('noKOTModal').classList.remove('open')">Close</button>
            <button class="no-btn no-btn-red" onclick="printZone('noKOTPrint')"><i class="fas fa-print"></i> Print KOT</button>
        </div>
    </div>
</div>

<div class="no-modal-bg" id="noBillModal">
    <div class="no-modal-box" style="max-width:440px">
        <div class="no-modal-hdr">
            <h4><i class="fas fa-file-invoice" style="color:#27ae60;margin-right:6px"></i>Order Bill</h4>
            <button class="no-modal-x" onclick="document.getElementById('noBillModal').classList.remove('open')">&times;</button>
        </div>
        <div class="no-modal-body"><div class="no-pzone" id="noBillPrint"></div></div>
        <div class="no-modal-ftr">
            <button class="no-btn no-btn-gh"  onclick="document.getElementById('noBillModal').classList.remove('open')">Close</button>
            <button class="no-btn no-btn-gh"  onclick="printZone('noBillPrint')"><i class="fas fa-print"></i> Print</button>
            <button class="no-btn no-btn-grn" onclick="doneBill('noBillModal')"><i class="fas fa-check"></i> Done</button>
        </div>
    </div>
</div>

<div id="noToast"></div>
