@{
    ViewData["Title"] = "Manage Menu";
}

@section styles {
    <style>


        /* Three-column equal-height grid */
        .menu-grid {
            display: grid;
            grid-template-columns: repeat(3, 1fr);
            gap: 20px;
            align-items: start;
        }

        @@media(max-width:1024px) {
            .menu-grid {
                grid-template-columns: 1fr 1fr;
            }
        }

        @@media(max-width:640px) {
            .menu-grid {
                grid-template-columns: 1fr;
            }
        }

        /* Table count card — half width on md+ */
        .table-count-wrap {
            max-width: 360px;
            margin-bottom: 24px;
        }

        /* Tighter table inside cards */
        .menu-table {
            width: 100%;
            border-collapse: collapse;
            font-size: .82rem;
        }

            .menu-table thead th {
                background: var(--gns-surface-2);
                color: var(--gns-text-muted);
                font-size: .68rem;
                font-weight: 700;
                letter-spacing: .08em;
                text-transform: uppercase;
                padding: 9px 12px;
                border-bottom: 1px solid var(--gns-border);
                white-space: nowrap;
            }

            .menu-table tbody td {
                padding: 9px 12px;
                border-bottom: 1px solid var(--gns-border);
                color: var(--gns-text);
                vertical-align: middle;
            }

            .menu-table tbody tr:last-child td {
                border-bottom: none;
            }

            .menu-table tbody tr {
                transition: background var(--transition);
            }

                .menu-table tbody tr:hover {
                    background: var(--gns-surface-2);
                }

        /* Pagination override */
        .menu-pager {
            display: flex;
            gap: 4px;
            flex-wrap: wrap;
            padding: 12px 14px 4px;
            border-top: 1px solid var(--gns-border);
        }

            .menu-pager .page-item.disabled .page-link {
                opacity: .4;
                pointer-events: none;
            }

            .menu-pager .page-link {
                display: inline-flex;
                align-items: center;
                justify-content: center;
                min-width: 28px;
                height: 28px;
                padding: 0 7px;
                border-radius: var(--gns-radius-sm);
                border: 1px solid var(--gns-border);
                background: var(--gns-surface-2);
                color: var(--gns-text-muted);
                font-size: .75rem;
                font-weight: 600;
                cursor: pointer;
                text-decoration: none;
                transition: all .2s;
            }

                .menu-pager .page-link:hover {
                    background: var(--gns-accent-dim);
                    color: var(--gns-accent);
                    border-color: var(--gns-accent);
                }

            .menu-pager .page-item.active .page-link {
                background: var(--gns-accent);
                border-color: var(--gns-accent);
                color: #000;
                box-shadow: 0 2px 10px var(--gns-accent-glow);
            }

        /* Item image thumbnail */
        .item-thumb {
            width: 48px;
            height: 48px;
            object-fit: cover;
            border-radius: var(--gns-radius-sm);
            border: 1px solid var(--gns-border);
        }

        .no-image-pill {
            display: inline-flex;
            align-items: center;
            justify-content: center;
            width: 48px;
            height: 48px;
            border-radius: var(--gns-radius-sm);
            background: var(--gns-surface-2);
            border: 1px dashed var(--gns-border);
            color: var(--gns-text-muted);
            font-size: .65rem;
            text-align: center;
            line-height: 1.2;
        }

        /* Table count value display */
        .table-count-val {
            font-family: 'Syne', sans-serif;
            font-size: 2rem;
            font-weight: 800;
            color: var(--gns-accent);
            line-height: 1;
        }

        /* Modal form layout */
        .gns-modal-form .modal-header {
            background: var(--gns-surface-2) !important;
            border-bottom: 1px solid var(--gns-border) !important;
            padding: 16px 22px !important;
        }

        .gns-modal-form .modal-body {
            padding: 22px !important;
            background: var(--gns-surface) !important;
        }

        .gns-modal-form .modal-footer {
            background: var(--gns-surface-2) !important;
            border-top: 1px solid var(--gns-border) !important;
            padding: 14px 22px !important;
            gap: 10px;
        }

        /* Custom file input */
        .gns-file-wrap {
            position: relative;
            display: flex;
            align-items: center;
            gap: 10px;
        }

            .gns-file-wrap input[type="file"] {
                position: absolute;
                inset: 0;
                opacity: 0;
                cursor: pointer;
                z-index: 2;
                width: 100%;
                height: 100%;
            }

        .gns-file-btn {
            display: inline-flex;
            align-items: center;
            gap: 6px;
            padding: 9px 16px;
            border-radius: var(--gns-radius-sm);
            border: 1px dashed var(--gns-border);
            background: var(--gns-surface-2);
            color: var(--gns-text-muted);
            font-size: .82rem;
            font-weight: 500;
            cursor: pointer;
            transition: all .2s;
            white-space: nowrap;
            flex-shrink: 0;
        }

            .gns-file-btn:hover {
                border-color: var(--gns-accent);
                color: var(--gns-accent);
                background: var(--gns-accent-dim);
            }

        .gns-file-name {
            font-size: .8rem;
            color: var(--gns-text-muted);
            overflow: hidden;
            text-overflow: ellipsis;
            white-space: nowrap;
        }

        /* Image preview */
        #itemImagePreview {
            width: 80px;
            height: 80px;
            object-fit: cover;
            border-radius: var(--gns-radius-sm);
            border: 1px solid var(--gns-border);
            display: none;
        }

        /* Form check / toggle */
        .gns-check {
            display: flex;
            align-items: center;
            gap: 10px;
            cursor: pointer;
        }

            .gns-check input[type="checkbox"] {
                width: 18px;
                height: 18px;
                accent-color: var(--gns-accent);
                cursor: pointer;
            }

        .gns-check-label {
            font-size: .88rem;
            color: var(--gns-text);
            font-weight: 500;
        }

        /* Error text */
        .gns-error {
            font-size: .78rem;
            color: #ef4444;
            margin-top: 6px;
        }
    </style>
}

<div class="gns-page-header">
    <div>
        <h1><i class="fas fa-utensils me-2" style="color:var(--gns-accent)"></i>Manage Menu</h1>
        <p>Manage categories, subcategories and menu items</p>
    </div>
</div>

<!-- ── Table Count ─────────────────────────────────────── -->
<div class="table-count-wrap">
    <div class="gns-card">
        <div class="gns-card__header">
            <h3 class="gns-card__title">
                <i class="fas fa-chair me-2" style="color:var(--gns-accent)"></i>Table Count
            </h3>
            <button id="editTableCountBtn"
                    class="btn-gns btn-gns-primary"
                    style="padding:6px 14px;font-size:.8rem"
                    data-toggle="modal"
                    data-target="#editTableCountModal">
                <i class="fas fa-pen"></i> Edit
            </button>
        </div>
        <div class="gns-card__body" style="padding:20px 22px">
            <div class="table-count-val" id="tableCount">—</div>
            <div style="font-size:.75rem;color:var(--gns-text-muted);margin-top:4px">tables configured</div>
        </div>
    </div>
</div>

<!-- ── Three Column Grid ──────────────────────────────── -->
<div class="menu-grid">

    <!-- CATEGORIES -->
    <div class="gns-card">
        <div class="gns-card__header">
            <h3 class="gns-card__title">
                <i class="fas fa-layer-group me-2" style="color:var(--gns-accent)"></i>Categories
            </h3>
            <button class="btn-gns btn-gns-primary"
                    id="btnAddCategory"
                    style="padding:6px 14px;font-size:.8rem"
                    data-toggle="modal"
                    data-target="#categoryModal">
                <i class="fas fa-plus"></i> Add
            </button>
        </div>
        <div style="overflow-x:auto">
            <table class="menu-table" id="categoryTable">
                <thead>
                    <tr>
                        <th style="width:36px">ID</th>
                        <th>Category</th>
                        <th style="width:52px">Active</th>
                        <th style="width:52px"></th>
                    </tr>
                </thead>
                <tbody></tbody>
            </table>
        </div>
        <nav>
            <ul id="categoryPager" class="menu-pager"></ul>
        </nav>
    </div>

    <!-- SUBCATEGORIES -->
    <div class="gns-card">
        <div class="gns-card__header">
            <h3 class="gns-card__title">
                <i class="fas fa-tags me-2" style="color:var(--gns-accent)"></i>Subcategories
            </h3>
            <button class="btn-gns btn-gns-primary"
                    id="btnAddSubcategory"
                    style="padding:6px 14px;font-size:.8rem"
                    data-toggle="modal"
                    data-target="#subcategoryModal">
                <i class="fas fa-plus"></i> Add
            </button>
        </div>
        <div style="overflow-x:auto">
            <table class="menu-table" id="subcategoryTable">
                <thead>
                    <tr>
                        <th style="width:36px">ID</th>
                        <th>Category</th>
                        <th>Subcategory</th>
                        <th style="width:52px">Active</th>
                        <th style="width:52px"></th>
                    </tr>
                </thead>
                <tbody></tbody>
            </table>
        </div>
        <nav>
            <ul id="subcategoryPager" class="menu-pager"></ul>
        </nav>
    </div>

    <!-- MENU ITEMS -->
    <div class="gns-card">
        <div class="gns-card__header">
            <h3 class="gns-card__title">
                <i class="fas fa-burger me-2" style="color:var(--gns-accent)"></i>Menu Items
            </h3>
            <button class="btn-gns btn-gns-primary"
                    id="btnAddItem"
                    style="padding:6px 14px;font-size:.8rem"
                    data-toggle="modal"
                    data-target="#itemModal">
                <i class="fas fa-plus"></i> Add
            </button>
        </div>
        <div style="overflow-x:auto">
            <table class="menu-table" id="itemTable">
                <thead>
                    <tr>
                        <th style="width:36px">ID</th>
                        <th style="width:58px">Image</th>
                        <th>Item</th>
                        <th>Category</th>
                        <th>Sub</th>
                        <th style="width:72px">Full ₹</th>
                        <th style="width:72px">Half ₹</th>
                        <th style="width:52px">Active</th>
                        <th style="width:52px"></th>
                    </tr>
                </thead>
                <tbody></tbody>
            </table>
        </div>
        <nav>
            <ul id="itemPager" class="menu-pager"></ul>
        </nav>
    </div>

</div>

<!-- ═══════════════════════════════════════════════════════
     MODALS
═══════════════════════════════════════════════════════ -->
<!-- Category Modal -->
<div class="modal fade" id="categoryModal" tabindex="-1" role="dialog" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <form id="categoryForm" class="modal-content gns-modal-form">
            <div class="modal-header">
                <div>
                    <h5 class="modal-title" id="categoryModalTitle">Add Category</h5>
                    <div style="font-size:.72rem;color:var(--gns-text-muted);margin-top:1px">Fill in the details below</div>
                </div>
                <button type="button" class="close" data-dismiss="modal" aria-label="Close"
                        style="background:none;border:1px solid var(--gns-border);border-radius:var(--gns-radius-sm);color:var(--gns-text-muted);width:32px;height:32px;display:flex;align-items:center;justify-content:center;font-size:1rem;cursor:pointer;transition:.2s;flex-shrink:0">
                    <span aria-hidden="true">&times;</span>
                </button>
            </div>
            <div class="modal-body">
                <input type="hidden" id="categoryId" />
                <div class="gns-form-group">
                    <label for="categoryName">Category Name</label>
                    <input id="categoryName" class="gns-form-control" placeholder="e.g. Beverages" required />
                </div>
                <label class="gns-check">
                    <input id="categoryIsActive" type="checkbox" checked />
                    <span class="gns-check-label">Is Active</span>
                </label>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn-gns btn-gns-ghost" data-dismiss="modal">
                    <i class="fas fa-times"></i> Cancel
                </button>
                <button class="btn-gns btn-gns-primary" type="submit">
                    <i class="fas fa-save"></i> Save
                </button>
            </div>
        </form>
    </div>
</div>

<!-- Subcategory Modal -->
<div class="modal fade" id="subcategoryModal" tabindex="-1" role="dialog" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <form id="subcategoryForm" class="modal-content gns-modal-form">
            <div class="modal-header">
                <div>
                    <h5 class="modal-title" id="subcategoryModalTitle">Add Subcategory</h5>
                    <div style="font-size:.72rem;color:var(--gns-text-muted);margin-top:1px">Select a parent category first</div>
                </div>
                <button type="button" class="close" data-dismiss="modal" aria-label="Close"
                        style="background:none;border:1px solid var(--gns-border);border-radius:var(--gns-radius-sm);color:var(--gns-text-muted);width:32px;height:32px;display:flex;align-items:center;justify-content:center;font-size:1rem;cursor:pointer;transition:.2s;flex-shrink:0">
                    <span aria-hidden="true">&times;</span>
                </button>
            </div>
            <div class="modal-body">
                <input type="hidden" id="subcategoryId" />
                <div class="gns-form-group">
                    <label for="subcategoryCategoryId">Parent Category</label>
                    <select id="subcategoryCategoryId" class="gns-form-control" required>
                        <option value="">Select category</option>
                    </select>
                </div>
                <div class="gns-form-group">
                    <label for="subcategoryName">Subcategory Name</label>
                    <input id="subcategoryName" class="gns-form-control" placeholder="e.g. Cold Drinks" required />
                </div>
                <label class="gns-check">
                    <input id="subcategoryIsActive" type="checkbox" checked />
                    <span class="gns-check-label">Is Active</span>
                </label>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn-gns btn-gns-ghost" data-dismiss="modal">
                    <i class="fas fa-times"></i> Cancel
                </button>
                <button class="btn-gns btn-gns-primary" type="submit">
                    <i class="fas fa-save"></i> Save
                </button>
            </div>
        </form>
    </div>
</div>

<!-- Item Modal -->
<div class="modal fade" id="itemModal" tabindex="-1" role="dialog" aria-hidden="true">
    <div class="modal-dialog modal-lg modal-dialog-centered">
        <form id="itemForm" class="modal-content gns-modal-form" enctype="multipart/form-data">
            <div class="modal-header">
                <div>
                    <h5 class="modal-title" id="itemModalTitle">Add Menu Item</h5>
                    <div style="font-size:.72rem;color:var(--gns-text-muted);margin-top:1px">Fill in all required fields</div>
                </div>
                <button type="button" class="close" data-dismiss="modal" aria-label="Close"
                        style="background:none;border:1px solid var(--gns-border);border-radius:var(--gns-radius-sm);color:var(--gns-text-muted);width:32px;height:32px;display:flex;align-items:center;justify-content:center;font-size:1rem;cursor:pointer;transition:.2s;flex-shrink:0">
                    <span aria-hidden="true">&times;</span>
                </button>
            </div>
            <div class="modal-body">
                <input type="hidden" id="itemId" />
                <div class="gns-form-grid">
                    <div class="gns-form-group">
                        <label for="itemCategoryId">Category</label>
                        <select id="itemCategoryId" class="gns-form-control" required>
                            <option value="">Select category</option>
                        </select>
                    </div>
                    <div class="gns-form-group">
                        <label for="itemSubcategoryId">Subcategory</label>
                        <select id="itemSubcategoryId" class="gns-form-control" required>
                            <option value="">Select subcategory</option>
                        </select>
                    </div>
                </div>

                <div class="gns-form-group">
                    <label for="itemTitle">Item Title</label>
                    <input id="itemTitle" class="gns-form-control" placeholder="e.g. Grilled Chicken Burger" required />
                </div>

                <div class="gns-form-grid">
                    <div class="gns-form-group">
                        <label for="itemFullPrice">Full Price (₹)</label>
                        <input id="itemFullPrice" class="gns-form-control" type="number" min="0" step="0.01" placeholder="0.00" />
                    </div>
                    <div class="gns-form-group">
                        <label for="itemHalfPrice">Half Price (₹)</label>
                        <input id="itemHalfPrice" class="gns-form-control" type="number" min="0" step="0.01" placeholder="0.00" />
                    </div>
                </div>

                <div class="gns-form-group">
                    <label for="itemDescription">Description</label>
                    <textarea id="itemDescription"
                              class="gns-form-control"
                              rows="3"
                              placeholder="Short description of the item…"></textarea>
                </div>

                <div class="gns-form-group">
                    <label>Item Image</label>
                    <div style="display:flex;align-items:center;gap:14px;flex-wrap:wrap">
                        <div class="gns-file-wrap" style="position:relative">
                            <input type="file" id="itemImage" accept="image/*" />
                            <div class="gns-file-btn">
                                <i class="fas fa-upload"></i>
                                <span id="fileLabel">Choose file</span>
                            </div>
                        </div>
                        <img id="itemImagePreview" src="" alt="Preview" />
                    </div>
                </div>

                <label class="gns-check">
                    <input id="itemIsActive" type="checkbox" checked />
                    <span class="gns-check-label">Is Active</span>
                </label>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn-gns btn-gns-ghost" data-dismiss="modal">
                    <i class="fas fa-times"></i> Cancel
                </button>
                <button class="btn-gns btn-gns-primary" type="submit">
                    <i class="fas fa-save"></i> Save Item
                </button>
            </div>
        </form>
    </div>
</div>

<!-- Edit Table Count Modal -->
<div class="modal fade" id="editTableCountModal" tabindex="-1" role="dialog" aria-hidden="true">
    <div class="modal-dialog modal-sm modal-dialog-centered">
        <form id="editTableCountForm" class="modal-content gns-modal-form">
            <div class="modal-header">
                <div>
                    <h5 class="modal-title">Edit Table Count</h5>
                    <div style="font-size:.72rem;color:var(--gns-text-muted);margin-top:1px">Set total number of tables</div>
                </div>
                <button type="button" class="close" data-dismiss="modal" aria-label="Close"
                        style="background:none;border:1px solid var(--gns-border);border-radius:var(--gns-radius-sm);color:var(--gns-text-muted);width:32px;height:32px;display:flex;align-items:center;justify-content:center;font-size:1rem;cursor:pointer;transition:.2s;flex-shrink:0">
                    <span aria-hidden="true">&times;</span>
                </button>
            </div>
            <div class="modal-body">
                <div class="gns-form-group" style="margin-bottom:8px">
                    <label for="tableCountInput">Number of Tables</label>
                    <input id="tableCountInput"
                           class="gns-form-control"
                           type="number"
                           min="1"
                           step="1"
                           placeholder="e.g. 12"
                           required />
                </div>
                <div id="tableCountError" class="gns-error" style="display:none"></div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn-gns btn-gns-ghost" id="cancelTableCountBtn" data-dismiss="modal">
                    <i class="fas fa-times"></i> Cancel
                </button>
                <button type="submit" class="btn-gns btn-gns-primary" id="saveTableCountBtn">
                    <i class="fas fa-save"></i> Save
                </button>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <script>
        const PAGE_SIZE = 7;

        let categoriesData    = [];
        let subcategoriesData = [];
        let itemsData         = [];
        let masterSubcategoryOptionsHtml = '';
        let categoryPage    = 1;
        let subcategoryPage = 1;
        let itemPage        = 1;

        $(document).ready(function () {
            $('#switchOnOff').hide();
            $('#manageLink').hide();
            $('#homeLink').show();

            // ── render helpers: replace badge HTML to use gns-badge ──
            // (renderCategoryPage / renderSubcategoryPage / renderItemPage call these)

            $('#btnAddCategory').on('click', function () {
                $('#categoryModalTitle').text('Add Category');
                $('#categoryForm')[0]?.reset();
                $('#categoryId').val('');
            });
            $('#btnAddSubcategory').on('click', function () {
                $('#subcategoryModalTitle').text('Add Subcategory');
                $('#subcategoryForm')[0]?.reset();
                $('#subcategoryId').val('');
            });
            $('#btnAddItem').on('click', function () {
                $('#itemModalTitle').text('Add Menu Item');
                $('#itemForm')[0]?.reset();
                $('#itemId').val('');
                populateCategorySelects();
                populateSubcategorySelect();
                loadSubcategoriesForCategory('', null);
                $('#itemCategoryId').val('');
                $('#itemSubcategoryId').val('');
                $('#fileLabel').text('Choose file');
                $('#itemImagePreview').hide().attr('src', '');
                $('#itemFullPrice').val('');
                $('#itemHalfPrice').val('');
            });

            $(document).on('change', '#itemCategoryId', function () {
                const catId = $(this).val();
                loadSubcategoriesForCategory(catId, null);
                $('#itemSubcategoryId').val('');
            });

            loadAll();
            loadTableCount();

            $('#editTableCountBtn').on('click', function () {
                const current = parseInt($('#tableCount').text(), 10);
                $('#tableCountInput').val(!isNaN(current) && current > 0 ? current : 1);
                $('#tableCountError').hide().text('');
            });

            $('#editTableCountForm').on('submit', function (e) {
                e.preventDefault();
                $('#tableCountError').hide().text('');
                let value = parseInt($('#tableCountInput').val(), 10);
                if (isNaN(value) || value < 1) {
                    $('#tableCountError').show().text('Please enter a valid number (>= 1).');
                    return;
                }
                const $btn = $('#saveTableCountBtn');
                $btn.prop('disabled', true).html('<i class="fas fa-spinner fa-spin"></i> Saving…');
                $.ajax({
                    url: '/Home/SaveTableCount',
                    type: 'POST',
                    contentType: 'application/json',
                    data: JSON.stringify(value),
                    success: function () {
                        $('#tableCount').text(value);
                        $('#editTableCountModal').modal('hide');
                        if (typeof bindDynamicTable === 'function') {
                            arrTable = Array.from({ length: value }, (_, i) => i + 1);
                            bindDynamicTable();
                        }
                    },
                    error: function (xhr) {
                        const msg = xhr.responseText || 'Failed to save table count';
                        $('#tableCountError').show().text(msg);
                    },
                    complete: function () {
                        $btn.prop('disabled', false).html('<i class="fas fa-save"></i> Save');
                    }
                });
            });

            // file input: update label + preview
            $(document).on('change', '#itemImage', function () {
                const f = this.files && this.files[0];
                if (f) {
                    $('#fileLabel').text(f.name);
                    const reader = new FileReader();
                    reader.onload = function (e) {
                        $('#itemImagePreview').attr('src', e.target.result).show();
                    };
                    reader.readAsDataURL(f);
                } else {
                    $('#fileLabel').text('Choose file');
                    $('#itemImagePreview').hide().attr('src', '');
                }
            });

            $('.modal').on('hidden.bs.modal', function () {
                $(this).find('form')[0]?.reset();
                $(this).find('input[type="hidden"]').val('');
                $('#itemImagePreview').hide().attr('src', '');
                $('#fileLabel').text('Choose file');
                populateCategorySelects();
                populateSubcategorySelect();
            });

            bindFormHandlers();
        });

        /* ── badge helper ─────────────────────────────── */
        function activeBadge(active) {
            return active
                ? '<span class="gns-badge gns-badge-active"><i class="fas fa-circle" style="font-size:.45rem"></i>Yes</span>'
                : '<span class="gns-badge gns-badge-inactive"><i class="fas fa-circle" style="font-size:.45rem"></i>No</span>';
        }

        /* ── edit button helper ───────────────────────── */
        function editBtn(cls, id) {
            return `<button class="tbl-btn tbl-btn-edit ${cls}" data-id="${id}" title="Edit">
                        <i class="fas fa-pen"></i>
                    </button>`;
        }

        /* ── form handlers ────────────────────────────── */
        function bindFormHandlers() {
            $('#categoryForm').off('submit').on('submit', function (e) {
                e.preventDefault();
                const id = $('#categoryId').val();
                const payload = {
                    CategoryId: id || 0,
                    CategoryName: $('#categoryName').val(),
                    IsActive: $('#categoryIsActive').is(':checked')
                };
                $.ajax({
                    url: id ? `/Home/SaveMenuCategory?id=${id}` : '/Home/SaveMenuCategory',
                    method: id ? 'PUT' : 'POST',
                    contentType: 'application/json',
                    data: JSON.stringify(payload),
                    success: function () {
                        $('#categoryModal').modal('hide');
                        loadMenuCategories();
                        loadMenuSubcategories();
                    },
                    error: function () { alert('Failed to save category'); }
                });
            });

            $('#subcategoryForm').off('submit').on('submit', function (e) {
                e.preventDefault();
                const id = $('#subcategoryId').val();
                const payload = {
                    SubcategoryId: id || 0,
                    CategoryId: $('#subcategoryCategoryId').val(),
                    SubcategoryName: $('#subcategoryName').val(),
                    IsActive: $('#subcategoryIsActive').is(':checked')
                };
                $.ajax({
                    url: id ? `/Home/SaveMenuSubcategory?id=${id}` : '/Home/SaveMenuSubcategory',
                    method: id ? 'PUT' : 'POST',
                    contentType: 'application/json',
                    data: JSON.stringify(payload),
                    success: function () {
                        $('#subcategoryModal').modal('hide');
                        loadMenuSubcategories();
                        loadMenuItems();
                    },
                    error: function () { alert('Failed to save subcategory'); }
                });
            });

            $('#itemForm').off('submit').on('submit', function (e) {
                e.preventDefault();
                const id = $('#itemId').val();
                const fm = new FormData();
                fm.append('ItemId', id || 0);
                fm.append('CategoryId', $('#itemCategoryId').val());
                fm.append('SubcategoryId', $('#itemSubcategoryId').val());
                fm.append('ItemName', $('#itemTitle').val());
                fm.append('Description', $('#itemDescription').val());
                fm.append('price1', $('#itemFullPrice').val() || 0);
                fm.append('price2', $('#itemHalfPrice').val() || 0);
                fm.append('IsActive', $('#itemIsActive').is(':checked'));
                const file = $('#itemImage')[0].files[0];
                if (file) fm.append('image', file);
                $.ajax({
                    url: id ? `/Home/SaveMenuItem?id=${id}` : '/Home/SaveMenuItem',
                    method: id ? 'PUT' : 'POST',
                    data: fm,
                    contentType: false,
                    processData: false,
                    success: function () {
                        $('#itemModal').modal('hide');
                        loadMenuItems();
                    },
                    error: function () { alert('Failed to save item'); }
                });
            });

            /* edit category */
            $('#categoryTable').off('click', '.edit-category').on('click', '.edit-category', function () {
                const id = $(this).data('id');
                const found = categoriesData.find(x => String(x.categoryId ?? x.CategoryId) === String(id));
                if (!found) { alert('Category not found'); return; }
                $('#categoryId').val(found.categoryId ?? found.CategoryId);
                $('#categoryName').val(found.categoryName ?? found.CategoryName);
                $('#categoryIsActive').prop('checked', !!(found.isActive ?? found.IsActive));
                $('#categoryModalTitle').text('Edit Category');
                $('#categoryModal').modal('show');
            });

            /* edit subcategory */
            $('#subcategoryTable').off('click', '.edit-subcategory').on('click', '.edit-subcategory', function () {
                const id = $(this).data('id');
                const found = subcategoriesData.find(x => String(x.subcategoryId ?? x.SubcategoryId) === String(id));
                if (!found) { alert('Subcategory not found'); return; }
                $('#subcategoryId').val(found.subcategoryId ?? found.SubcategoryId);
                $('#subcategoryName').val(found.subcategoryName ?? found.SubcategoryName);
                $('#subcategoryIsActive').prop('checked', !!(found.isActive ?? found.IsActive));
                populateCategorySelects();
                $('#subcategoryCategoryId').val(found.categoryId ?? found.CategoryId);
                $('#subcategoryModalTitle').text('Edit Subcategory');
                $('#subcategoryModal').modal('show');
            });

            /* edit item */
            $('#itemTable').off('click', '.edit-item').on('click', '.edit-item', function () {
                const id = $(this).data('id');
                const found = itemsData.find(x => String(x.itemId ?? x.ItemId) === String(id));
                if (!found) { alert('Item not found'); return; }

                $('#itemId').val(found.itemId ?? found.ItemId);
                $('#itemTitle').val(found.itemName ?? found.ItemName ?? found.title ?? found.Title);
                $('#itemDescription').val(found.description ?? found.Description);
                $('#itemFullPrice').val(found.price1 ?? found.Price1 ?? found.fullPrice ?? '');
                $('#itemHalfPrice').val(found.price2 ?? found.Price2 ?? found.halfPrice ?? '');
                $('#itemIsActive').prop('checked', !!(found.isActive ?? found.IsActive));

                const subId = found.subcategoryId ?? found.SubcategoryId ?? null;
                const subObj = subcategoriesData.find(s => String(s.subcategoryId ?? s.SubcategoryId) === String(subId));
                const catIdFromItem = found.categoryId ?? found.CategoryId ?? null;
                const derivedCatId = (catIdFromItem !== undefined && catIdFromItem !== null && String(catIdFromItem) !== '')
                    ? String(catIdFromItem)
                    : (subObj ? String(subObj.categoryId ?? subObj.CategoryId ?? '') : '');

                populateCategorySelects();
                populateSubcategorySelect();
                $('#itemCategoryId').val(derivedCatId || '');
                loadSubcategoriesForCategory(derivedCatId, function () {
                    $('#itemSubcategoryId').val(subId == null ? '' : String(subId));
                });

                if (found.imageSrc) {
                    const src = normalizeImageSrc(found.imageSrc);
                    $('#itemImagePreview').attr('src', src).show();
                    $('#fileLabel').text(found.itemName ?? 'Image');
                } else if (found.imageData && found.itemName) {
                    const mime = getMimeFromName(found.itemName);
                    $('#itemImagePreview').attr('src', `data:${mime};base64,${found.imageData}`).show();
                    $('#fileLabel').text(found.itemName);
                } else if (found.imageUrl) {
                    $('#itemImagePreview').attr('src', found.imageUrl).show();
                    $('#fileLabel').text(found.itemName ?? 'Image');
                } else {
                    $('#itemImagePreview').hide().attr('src', '');
                    $('#fileLabel').text('Choose file');
                }

                $('#itemModalTitle').text('Edit Item');
                $('#itemModal').modal('show');
            });
        }

        /* ── Load helpers ───────────────────────────────── */
        function loadAll() {
            loadTableCount();
            loadMenuCategories();
            loadMenuSubcategories();
            loadMenuItems();
        }

        function loadTableCount() {
            $.ajax({
                url: '/Home/GetTableCount',
                type: 'GET',
                success: function (data) {
                    let count = data;
                    if (typeof data === 'object' && data !== null) {
                        count = data.count ?? data.TableCount ?? data;
                    }
                    const n = parseInt(count, 10);
                    $('#tableCount').text(!isNaN(n) ? n : count);
                    if (!isNaN(n) && typeof bindDynamicTable === 'function') {
                        arrTable = Array.from({ length: n }, (_, i) => i + 1);
                        bindDynamicTable();
                    }
                },
                error: function () { $('#tableCount').text('N/A'); }
            });
        }

        function loadMenuCategories() {
            $.ajax({
                url: '/Home/GetMenuCategory',
                type: 'GET',
                success: function (data) {
                    categoriesData = data || [];
                    categoryPage = 1;
                    renderCategoryPage(categoryPage);
                    populateCategorySelects();
                },
                error: function () { alert('Failed to load categories'); }
            });
        }

        function renderCategoryPage(page) {
            const rows = $('#categoryTable tbody');
            rows.empty();
            const total = categoriesData.length;
            const totalPages = Math.max(1, Math.ceil(total / PAGE_SIZE));
            page = Math.min(Math.max(1, page), totalPages);
            categoryPage = page;
            const start = (page - 1) * PAGE_SIZE;
            categoriesData.slice(start, start + PAGE_SIZE).forEach(cat => {
                const id     = cat.categoryId ?? cat.CategoryId;
                const name   = cat.categoryName ?? cat.CategoryName;
                const active = !!(cat.isActive ?? cat.IsActive);
                rows.append(`<tr>
                    <td>${id}</td>
                    <td>${escapeHtml(name)}</td>
                    <td>${activeBadge(active)}</td>
                    <td>${editBtn('edit-category', id)}</td>
                </tr>`);
            });
            renderPager('#categoryPager', total, PAGE_SIZE, page, p => renderCategoryPage(p));
        }

        function loadMenuSubcategories() {
            $.ajax({
                url: '/Home/GetMenuSubcategory',
                type: 'GET',
                success: function (data) {
                    subcategoriesData = data || [];
                    subcategoryPage = 1;
                    renderSubcategoryPage(subcategoryPage);
                    populateSubcategorySelect();
                },
                error: function () { alert('Failed to load subcategories'); }
            });
        }

        function renderSubcategoryPage(page) {
            const rows = $('#subcategoryTable tbody');
            rows.empty();
            const total = subcategoriesData.length;
            const totalPages = Math.max(1, Math.ceil(total / PAGE_SIZE));
            page = Math.min(Math.max(1, page), totalPages);
            subcategoryPage = page;
            const start = (page - 1) * PAGE_SIZE;
            subcategoriesData.slice(start, start + PAGE_SIZE).forEach(sc => {
                const id     = sc.subcategoryId ?? sc.SubcategoryId;
                const name   = sc.subcategoryName ?? sc.SubcategoryName ?? '';
                const catId  = sc.categoryId ?? sc.CategoryId;
                const active = !!(sc.isActive ?? sc.IsActive);
                let catName  = sc.categoryName ?? sc.CategoryName ?? '';
                if (!catName && (catId !== undefined && catId !== null)) {
                    const foundCat = categoriesData.find(c => String(c.categoryId ?? c.CategoryId) === String(catId));
                    catName = foundCat ? (foundCat.categoryName ?? foundCat.CategoryName ?? '') : String(catId);
                }
                rows.append(`<tr>
                    <td>${id}</td>
                    <td>${escapeHtml(catName)}</td>
                    <td>${escapeHtml(name)}</td>
                    <td>${activeBadge(active)}</td>
                    <td>${editBtn('edit-subcategory', id)}</td>
                </tr>`);
            });
            renderPager('#subcategoryPager', total, PAGE_SIZE, page, p => renderSubcategoryPage(p));
        }

        function loadMenuItems() {
            $.ajax({
                url: '/Home/GetMenuItem',
                type: 'GET',
                success: function (data) {
                    itemsData = data || [];
                    itemPage = 1;
                    renderItemPage(itemPage);
                },
                error: function () { alert('Failed to load items'); }
            });
        }

        function normalizeImageSrc(src) {
            if (!src) return '';
            if (/^data:/.test(src)) return src;
            if (src.length > 100 && /^[A-Za-z0-9+/=]+$/.test(src)) return `data:image/jpeg;base64,${src}`;
            return src;
        }

        function renderItemPage(page) {
            const rows = $('#itemTable tbody');
            rows.empty();
            const total = itemsData.length;
            const totalPages = Math.max(1, Math.ceil(total / PAGE_SIZE));
            page = Math.min(Math.max(1, page), totalPages);
            itemPage = page;
            const start = (page - 1) * PAGE_SIZE;
            itemsData.slice(start, start + PAGE_SIZE).forEach(it => {
                const id   = it.itemId ?? it.ItemId;
                const title = it.itemName ?? it.ItemName ?? it.title ?? it.Title;
                const full = Number(it.price1 ?? it.Price1 ?? it.price ?? 0) || 0;
                const half = Number(it.price2 ?? it.Price2 ?? it.halfPrice ?? 0) || 0;
                const subId = it.subcategoryId ?? it.SubcategoryId ?? null;

                let imgHtml = '';
                if (it.imageData && it.itemName) {
                    const mime = getMimeFromName(it.itemName);
                    imgHtml = `<img src="data:${mime};base64,${it.imageData}" class="item-thumb" alt="${escapeHtml(title)}" />`;
                } else if (it.imageUrl) {
                    imgHtml = `<img src="${it.imageUrl}" class="item-thumb" alt="${escapeHtml(title)}" />`;
                } else if (it.imageSrc) {
                    const src = normalizeImageSrc(it.imageSrc);
                    imgHtml = `<img src="${src}" class="item-thumb" alt="${escapeHtml(title)}" />`;
                } else {
                    imgHtml = `<div class="no-image-pill"><span>No<br>img</span></div>`;
                }

                let subText = it.subcategoryName ?? it.SubcategoryName ?? '';
                let resolvedCatId = it.categoryId ?? it.CategoryId ?? null;
                if (!subText && subId) {
                    const foundSub = subcategoriesData.find(s => String(s.subcategoryId ?? s.SubcategoryId) === String(subId));
                    if (foundSub) {
                        subText = foundSub.subcategoryName ?? foundSub.SubcategoryName ?? '';
                        if (!resolvedCatId) resolvedCatId = foundSub.categoryId ?? foundSub.CategoryId ?? null;
                    }
                }
                let catText = it.categoryName ?? it.CategoryName ?? '';
                if (!catText && (resolvedCatId !== undefined && resolvedCatId !== null)) {
                    const foundCat = categoriesData.find(c => String(c.categoryId ?? c.CategoryId) === String(resolvedCatId));
                    catText = foundCat ? (foundCat.categoryName ?? foundCat.CategoryName ?? '') : String(resolvedCatId);
                }

                const active = !!(it.isActive ?? it.IsActive);
                rows.append(`<tr>
                    <td>${id}</td>
                    <td>${imgHtml}</td>
                    <td style="font-weight:500">${escapeHtml(title)}</td>
                    <td>${escapeHtml(catText)}</td>
                    <td>${escapeHtml(subText)}</td>
                    <td>₹${full.toFixed(2)}</td>
                    <td>₹${half.toFixed(2)}</td>
                    <td>${activeBadge(active)}</td>
                    <td>${editBtn('edit-item', id)}</td>
                </tr>`);
            });
            renderPager('#itemPager', total, PAGE_SIZE, page, p => renderItemPage(p));
        }

        function renderPager(sel, totalItems, pageSize, currentPage, onPage) {
            const $c = $(sel);
            $c.empty();
            const totalPages = Math.max(1, Math.ceil(totalItems / pageSize));
            $c.append(`<li class="page-item ${currentPage===1?'disabled':''}"><a class="page-link" href="#" data-page="${currentPage-1}">‹</a></li>`);
            const maxBtns = 5;
            let start = Math.max(1, currentPage - Math.floor(maxBtns/2));
            let end   = Math.min(totalPages, start + maxBtns - 1);
            if (end - start < maxBtns - 1) start = Math.max(1, end - maxBtns + 1);
            for (let p = start; p <= end; p++) {
                $c.append(`<li class="page-item ${p===currentPage?'active':''}"><a class="page-link" href="#" data-page="${p}">${p}</a></li>`);
            }
            $c.append(`<li class="page-item ${currentPage===totalPages?'disabled':''}"><a class="page-link" href="#" data-page="${currentPage+1}">›</a></li>`);
            $c.off('click').on('click', 'a.page-link', function (ev) {
                ev.preventDefault();
                const p = parseInt($(this).data('page'), 10);
                if (!isNaN(p) && p >= 1 && p <= totalPages) onPage(p);
            });
        }

        function populateCategorySelects() {
            const s1 = $('#subcategoryCategoryId'), s2 = $('#itemCategoryId');
            s1.empty().append('<option value="">Select category</option>');
            s2.empty().append('<option value="">Select category</option>');
            categoriesData.forEach(cat => {
                const id = cat.categoryId ?? cat.CategoryId;
                const name = cat.categoryName ?? cat.CategoryName ?? '';
                s1.append(`<option value="${id}">${escapeHtml(name)}</option>`);
                s2.append(`<option value="${id}">${escapeHtml(name)}</option>`);
            });
        }

        function populateSubcategorySelect() {
            masterSubcategoryOptionsHtml = '<option value="">Select subcategory</option>';
            subcategoriesData.forEach(sc => {
                const id   = String(sc.subcategoryId ?? sc.SubcategoryId ?? '');
                const name = sc.subcategoryName ?? sc.SubcategoryName ?? '';
                const catId= String(sc.categoryId ?? sc.CategoryId ?? '');
                masterSubcategoryOptionsHtml += `<option data-cat="${catId}" value="${id}">${escapeHtml(name)}</option>`;
            });
            $('#itemSubcategoryId').empty().append(masterSubcategoryOptionsHtml);
        }

        function loadSubcategoriesForCategory(categoryId, cb) {
            const $wrapper = $('<select>').html(masterSubcategoryOptionsHtml);
            const $allOpts = $wrapper.find('option[data-cat]');
            const $target  = $('#itemSubcategoryId');
            $target.empty().append('<option value="">Select subcategory</option>');
            $allOpts.each(function () {
                if (!categoryId || String($(this).data('cat')) === String(categoryId)) {
                    $target.append($(this).clone());
                }
            });
            if (typeof cb === 'function') cb();
        }

        function escapeHtml(s) {
            if (s === undefined || s === null) return '';
            return String(s).replace(/[&<>"'`]/g, m => ({'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":'&#39;','`':'&#96;'})[m]);
        }

        function getMimeFromName(name) {
            if (!name) return 'application/octet-stream';
            const ext = name.split('.').pop().toLowerCase();
            return { jpg:'image/jpeg', jpeg:'image/jpeg', png:'image/png', gif:'image/gif', webp:'image/webp' }[ext] || 'application/octet-stream';
        }

        window.menuManagement = { reload: loadAll };
    </script>
}
