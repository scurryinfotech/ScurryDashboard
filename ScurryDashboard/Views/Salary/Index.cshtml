@{
    ViewData["Title"] = "Salary Dashboard";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

@section Styles {
    <style>
        /* ── Summary Cards ───────────────────────────────────────────── */
        .sal-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(175px, 1fr));
            gap: 14px;
            margin-bottom: 26px;
        }

        .sal-card {
            background: var(--gns-surface);
            border: 1px solid var(--gns-border);
            border-radius: var(--gns-radius);
            padding: 20px 18px;
        }

        .sal-card__icon {
            width: 40px;
            height: 40px;
            border-radius: var(--gns-radius-sm);
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 1rem;
            margin-bottom: 12px;
        }

        .sal-card__val {
            font-family: 'Syne', sans-serif;
            font-size: 1.45rem;
            font-weight: 800;
            line-height: 1;
        }

        .sal-card__lbl {
            font-size: .7rem;
            color: var(--gns-text-muted);
            margin-top: 4px;
            text-transform: uppercase;
            letter-spacing: .07em;
        }

        .ic-amber {
            background: rgba(245,166,35,.15);
            color: var(--gns-accent);
        }

        .ic-blue {
            background: rgba(99,102,241,.12);
            color: #818cf8;
        }

        .ic-green {
            background: rgba(34,197,94,.12);
            color: #22c55e;
        }

        .ic-red {
            background: rgba(239,68,68,.12);
            color: #ef4444;
        }

        .ic-purple {
            background: rgba(168,85,247,.12);
            color: #c084fc;
        }

        /* ── Top bar ─────────────────────────────────────────────────── */
        .sal-topbar {
            display: flex;
            align-items: center;
            gap: 10px;
            flex-wrap: wrap;
            margin-bottom: 22px;
        }

            .sal-topbar select {
                max-width: 145px;
            }

        /* ── Status badges ───────────────────────────────────────────── */
        .sbadge {
            display: inline-block;
            padding: 3px 11px;
            border-radius: 99px;
            font-size: .7rem;
            font-weight: 700;
        }

        .sbadge-pending {
            background: rgba(239,68,68,.15);
            color: #ef4444;
        }

        .sbadge-partial {
            background: rgba(245,158,11,.15);
            color: #f59e0b;
        }

        .sbadge-paid {
            background: rgba(99,102,241,.12);
            color: #818cf8;
        }

        .sbadge-overpaid {
            background: rgba(34,197,94,.12);
            color: #22c55e;
        }

        .sbadge-none {
            background: var(--gns-surface-2);
            color: var(--gns-text-muted);
        }

        /* ── Balance colors ──────────────────────────────────────────── */
        .bal-red {
            color: #ef4444;
            font-family: 'Syne',sans-serif;
            font-weight: 800;
        }

        .bal-green {
            color: #22c55e;
            font-family: 'Syne',sans-serif;
            font-weight: 800;
        }

        .bal-blue {
            color: #818cf8;
            font-family: 'Syne',sans-serif;
            font-weight: 800;
        }

        /* ── Pay Modal ───────────────────────────────────────────────── */
        .pay-emp-card {
            background: var(--gns-surface-2);
            border-radius: var(--gns-radius-sm);
            padding: 16px;
            margin-bottom: 16px;
        }

        .pay-emp-name {
            font-family: 'Syne',sans-serif;
            font-size: 1.1rem;
            font-weight: 800;
        }

        .pay-emp-row {
            display: flex;
            gap: 20px;
            flex-wrap: wrap;
            margin-top: 8px;
        }

            .pay-emp-row span {
                font-size: .78rem;
                color: var(--gns-text-muted);
            }

            .pay-emp-row strong {
                color: var(--gns-text);
            }

        .pending-months {
            max-height: 190px;
            overflow-y: auto;
            margin-bottom: 14px;
        }

        .pm-row {
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding: 9px 13px;
            border-radius: 8px;
            background: var(--gns-surface-2);
            margin-bottom: 6px;
            font-size: .82rem;
        }

            .pm-row .pm-bal {
                font-family: 'Syne',sans-serif;
                font-weight: 800;
                color: #ef4444;
            }

        .pm-fifo-note {
            font-size: .7rem;
            color: var(--gns-text-muted);
            margin-bottom: 10px;
            display: flex;
            align-items: center;
            gap: 6px;
        }
    </style>
}

<!-- ── Page Header ── -->
<div class="gns-page-header">
    <div>
        <h1><i class="fas fa-money-check-dollar mr-2" style="color:var(--gns-accent)"></i>Salary Dashboard</h1>
        <p>Manage payroll, track payments and employee balances</p>
    </div>
</div>

<!-- ── Month / Year Selector ── -->
<div class="sal-topbar">
    <label style="color:var(--gns-text-muted);font-size:.82rem;font-weight:600">Month:</label>
    <select id="selMonth" class="gns-form-control">
        <option value="1">January</option>
        <option value="2">February</option>
        <option value="3">March</option>
        <option value="4">April</option>
        <option value="5">May</option>
        <option value="6">June</option>
        <option value="7">July</option>
        <option value="8">August</option>
        <option value="9">September</option>
        <option value="10">October</option>
        <option value="11">November</option>
        <option value="12">December</option>
    </select>
    <select id="selYear" class="gns-form-control" style="max-width:100px;"></select>
    <button class="btn-gns btn-gns-primary" id="btnLoad">
        <i class="fas fa-rotate-right"></i> Load
    </button>
    <button class="btn-gns btn-gns-ghost" id="btnGenAll">
        <i class="fas fa-wand-magic-sparkles"></i> Generate All
    </button>
</div>

<!-- ── Summary Cards ── -->
<div class="sal-grid">
    <div class="sal-card">
        <div class="sal-card__icon ic-amber"><i class="fas fa-users"></i></div>
        <div class="sal-card__val" id="sumEmp">—</div>
        <div class="sal-card__lbl">Employees</div>
    </div>
    <div class="sal-card">
        <div class="sal-card__icon ic-blue"><i class="fas fa-money-bill-wave"></i></div>
        <div class="sal-card__val" id="sumPayroll">—</div>
        <div class="sal-card__lbl">Total Payroll</div>
    </div>
    <div class="sal-card">
        <div class="sal-card__icon ic-green"><i class="fas fa-circle-check"></i></div>
        <div class="sal-card__val" id="sumPaid">—</div>
        <div class="sal-card__lbl">Total Paid</div>
    </div>
    <div class="sal-card">
        <div class="sal-card__icon ic-red"><i class="fas fa-hourglass-half"></i></div>
        <div class="sal-card__val" id="sumPending">—</div>
        <div class="sal-card__lbl">Total Pending</div>
    </div>
    <div class="sal-card">
        <div class="sal-card__icon ic-purple"><i class="fas fa-chart-pie"></i></div>
        <div class="sal-card__val" id="sumCounts">—</div>
        <div class="sal-card__lbl">Paid / Partial / Pending</div>
    </div>
</div>

<!-- ── Main Table ── -->
<div class="gns-card" style="position:relative">
    <div class="gns-loader" id="tblLoader"><div class="gns-spinner"></div></div>
    <div class="gns-card__header">
        <h2 class="gns-card__title">
            <i class="fas fa-table-list mr-2" style="color:var(--gns-accent)"></i>Employee Salary Status
        </h2>
    </div>
    <div class="gns-card__body" style="padding:0">
        <div class="table-responsive">
            <table id="salTable" class="table dataTable" style="width:100%">
                <thead>
                    <tr>
                        <th>Employee</th>
                        <th>Department</th>
                        <th>Basic</th>
                        <th>Net Salary</th>
                        <th>Paid</th>
                        <th>Balance</th>
                        <th>Status</th>
                        <th>Outstanding</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody></tbody>
            </table>
        </div>
    </div>
</div>

<!-- ================================================================
     PAY SALARY MODAL
================================================================ -->
<div class="modal fade" id="payModal" tabindex="-1">
    <div class="modal-dialog modal-lg modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">
                    <i class="fas fa-paper-plane mr-2" style="color:var(--gns-accent)"></i>Pay Salary
                </h5>
                <button type="button" class="close" data-dismiss="modal">&times;</button>
            </div>
            <div class="modal-body">

                <!-- Employee info card -->
                <div class="pay-emp-card">
                    <div class="pay-emp-name" id="payEmpName">—</div>
                    <div class="pay-emp-row">
                        <span>Dept: <strong id="payEmpDept">—</strong></span>
                        <span>Basic: <strong id="payEmpBasic">—</strong></span>
                        <span>Outstanding: <strong class="bal-red" id="payEmpOut">—</strong></span>
                    </div>
                </div>

                <!-- Pending months (FIFO preview) -->
                <div class="pm-fifo-note">
                    <i class="fas fa-info-circle" style="color:var(--gns-accent)"></i>
                    Payment clears <strong style="color:var(--gns-text)">oldest month first (FIFO)</strong>
                </div>
                <div class="pending-months" id="pendingMonths">
                    <div style="text-align:center;padding:12px;color:var(--gns-text-muted)">
                        <i class="fas fa-spinner fa-spin"></i> Loading…
                    </div>
                </div>

                <!-- Form fields -->
                <div class="gns-form-grid">
                    <div class="gns-form-group">
                        <label>Amount (Rs) <span style="color:#ef4444">*</span></label>
                        <input type="number" id="payAmt" class="gns-form-control"
                               placeholder="0.00" min="0.01" step="0.01" />
                    </div>
                    <div class="gns-form-group">
                        <label>Payment Date <span style="color:#ef4444">*</span></label>
                        <input type="date" id="payDate" class="gns-form-control" />
                    </div>
                </div>
                <div class="gns-form-grid">
                    <div class="gns-form-group">
                        <label>Payment Method <span style="color:#ef4444">*</span></label>
                        <select id="payMethod" class="gns-form-control">
                            <option value="Cash">Cash</option>
                            <option value="Online">Online</option>
                            <option value="Bank Transfer">Bank Transfer</option>
                        </select>
                    </div>
                    <div class="gns-form-group">
                        <label>Payment Type <span style="color:#ef4444">*</span></label>
                        <select id="payType" class="gns-form-control">
                            <option value="Full">Full</option>
                            <option value="Partial">Partial</option>
                            <option value="Advance">Advance</option>
                        </select>
                    </div>
                </div>
                <div class="gns-form-group">
                    <label>Reason</label>
                    <input type="text" id="payReason" class="gns-form-control"
                           placeholder="e.g. March 2026 salary" />
                </div>
                <div class="gns-form-group">
                    <label>Description</label>
                    <textarea id="payDesc" class="gns-form-control" rows="2"
                              placeholder="Additional notes…"></textarea>
                </div>

            </div>
            <div class="modal-footer">
                <button type="button" class="btn-gns btn-gns-ghost" data-dismiss="modal">Cancel</button>
                <button type="button" class="btn-gns btn-gns-primary" id="btnConfirmPay">
                    <i class="fas fa-paper-plane"></i> Confirm Payment
                </button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="~/js/salaryDashboard.js" asp-append-version="true"></script>
}
